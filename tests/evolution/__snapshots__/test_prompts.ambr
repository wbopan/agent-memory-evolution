  ```python
  from dataclasses import dataclass, field
  class KnowledgeItem:
      summary: str = ''
  class Query:
      query_text: str = ''
  class KnowledgeBase:
      def __init__(self, toolkit): self.toolkit = toolkit; self.raw_texts = []
      def write(self, item, raw_text): self.raw_texts.append(raw_text)
      def read(self, query): return self.toolkit.llm_completion([{'role':'user','content':'summarize'}])[:3000]
  
