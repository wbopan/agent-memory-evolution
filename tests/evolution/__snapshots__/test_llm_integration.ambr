# name: test_reflection
  dict({
    'output': '''
      Diagnosis:
      - The knowledge base was simply storing raw strings and returning the entire corpus regardless of the incoming question, so queries like “What is the capital of France?” never retrieved the relevant fact while returning unstructured data that the answerer couldn’t interpret.
      - There was no structured way for the agent to specify what topic or keywords it was looking for, so the read() implementation had no mechanism for targeted retrieval.
      - The new requirements also ask for explicit instructions so the observation/query agents can populate structured fields, which were missing and prevented the system from collecting actionable metadata.
      
      Fixes:
      1. Introduce structured Observation/Query dataclasses so facts are recorded with a topic, details, and optional source, and queries can specify topics plus detail keywords.
      2. Implement a SQLite-backed knowledge store with basic filtering using topic and keyword matches.
      3. Limit read() output to at most 1000 characters while still returning the most recent relevant entries and logging actions for transparency.
      4. Update the instruction constants to guide the LLMs to emit structured JSON for writing and querying, and to keep responses focused and concise.
      
      ```python
      from dataclasses import dataclass, field
      from typing import Optional
      
      # Clear instructions guide the observation/query agents and final response format.
      INSTRUCTION_OBSERVATION = (
          "Summarize a single fact by providing a topic, a concise detail about that topic, "
          "and an optional source if available; output must match the Observation schema."
      )
      INSTRUCTION_QUERY = (
          "Frame a query by naming the topic of interest and listing any keywords "
          "that should appear in the detail; follow the Query schema for your response."
      )
      INSTRUCTION_RESPONSE = (
          "Answer the user question with one or two factual sentences derived from the retrieved knowledge."
      )
      
      
      @dataclass
      class Observation:
          # Structured information keeps stored facts searchable and easy to match.
          topic: str = field(metadata={"description": "Short topic name or title for this fact"})
          details: str = field(metadata={"description": "Supporting detail or explanation for the topic"})
          source: Optional[str] = field(
              default=None,
              metadata={"description": "Optional source or reference for provenance"}
          )
      
      
      @dataclass
      class Query:
          # Topic + keywords let the read() method focus its retrieval.
          topic: Optional[str] = field(
              default=None,
              metadata={"description": "Primary topic to match when searching the knowledge base"}
          )
          detail_keywords: list[str] = field(
              default_factory=list,
              metadata={"description": "List of keywords to look for inside the detail text"}
          )
      
      
      class KnowledgeBase:
          """SQLite-backed knowledge base that filters observations by topic and keywords."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db = toolkit.db
              # Always ensure the table exists so writes can proceed without race conditions.
              with self.db:
                  self.db.execute(
                      """
                      CREATE TABLE IF NOT EXISTS observations (
                          id INTEGER PRIMARY KEY AUTOINCREMENT,
                          topic TEXT NOT NULL,
                          details TEXT NOT NULL,
                          source TEXT
                      )
                      """
                  )
              self.toolkit.logger.debug("Knowledge base initialized with SQLite table.")
      
          def write(self, observation: Observation) -> None:
              """Insert a single structured fact into the SQLite store for later retrieval."""
              with self.db:
                  self.db.execute(
                      "INSERT INTO observations (topic, details, source) VALUES (?, ?, ?)",
                      (observation.topic, observation.details, observation.source),
                  )
              self.toolkit.logger.debug(
                  f"Stored observation for topic='{observation.topic}' "
                  f"with details='{observation.details[:50]}...' "
                  f"and source='{observation.source}'."
              )
      
          def read(self, query: Query) -> str:
              """
              Retrieve up to a few recent observations matching the topic and keyword filters.
              The result is truncated to 1000 characters so it stays within the response budget.
              """
              self.toolkit.logger.debug(
                  f"Executing read with topic='{query.topic}' "
                  f"and keywords={query.detail_keywords}."
              )
      
              conditions = []
              params = []
      
              if query.topic:
                  conditions.append("topic LIKE ?")
                  params.append(f"%{query.topic}%")
      
              for keyword in query.detail_keywords:
                  clean_keyword = keyword.strip()
                  if not clean_keyword:
                      continue
                  conditions.append("(details LIKE ? OR topic LIKE ?)")
                  params.extend((f"%{clean_keyword}%", f"%{clean_keyword}%"))
      
              sql = "SELECT topic, details, COALESCE(source, '') FROM observations"
              if conditions:
                  sql += " WHERE " + " AND ".join(conditions)
              sql += " ORDER BY id DESC LIMIT 5"
      
              rows = list(self.db.execute(sql, params))
              self.toolkit.logger.debug(f"Retrieved {len(rows)} rows for the query.")
      
              if not rows:
                  self.toolkit.logger.debug("No matching observations found.")
                  return "No relevant information found."
      
              response_parts = []
              current_length = 0
              max_length = 1000
      
              for topic, details, source in rows:
                  snippet = f"{topic}: {details}"
                  if source:
                      snippet += f" (source: {source})"
                  delimiter = "\n" if response_parts else ""
                  snippet_length = len(delimiter) + len(snippet)
                  if current_length + snippet_length > max_length:
                      # If this is the first snippet and already too long, truncate it instead of dropping everything.
                      if not response_parts:
                          truncated = snippet[: max_length - len(" (truncated)")] + " (truncated)"
                          response_parts.append(truncated)
                      break
                  response_parts.append(f"{delimiter}{snippet}" if response_parts else snippet)
                  current_length += snippet_length
      
              result = "\n".join(part.lstrip("\n") for part in response_parts)
              self.toolkit.logger.debug(f"Read result length: {len(result)} chars.")
              return result[:max_length]
      ```
    ''',
    'prompt': '''
      You are an expert Python programmer specializing in knowledge base system design.
      
      Your task: Given a Knowledge Base Program (Python code defining Observation, Query, and KnowledgeBase classes), its evaluation score, and failed cases, diagnose the issues and fix them.
      
      <interface_spec>
      You are designing a Knowledge Base Program that implements three classes:
      
      1. **Observation** (dataclass): Defines what information is captured when writing to the knowledge base.
         - Must be a @dataclass with typed fields
         - An external LLM will populate instances by generating JSON matching your field definitions
         - **Field types MUST be JSON-compatible**: use only str, int, float, bool, list[str], Optional[str]
         - Do NOT use datetime, tuple, bytes, or custom objects — JSON cannot represent them
         - Use `field(metadata={"description": "..."})` to describe fields — descriptions are shown to the LLM that populates instances
      
      2. **Query** (dataclass): Defines what parameters are used when reading from the knowledge base.
         - Must be a @dataclass with typed fields
         - An external LLM will populate instances by generating JSON matching your field definitions
         - Same JSON-compatible type restriction and field description support as Observation
      
      3. **KnowledgeBase** (class): The core knowledge base system.
         - `__init__(self, toolkit)`: Receives a Toolkit with:
           - `toolkit.db`: sqlite3.Connection (in-memory SQLite)
           - `toolkit.chroma`: chromadb ephemeral client
           - `toolkit.llm_completion(messages, **kwargs) -> str`: LLM calls (budget-limited)
           - `toolkit.logger.debug(message)`: Debug logging (use liberally — logs are visible during diagnosis and help guide future fixes)
         - `write(self, observation: Observation) -> None`: Store information
         - `read(self, query: Query) -> str`: Retrieve relevant information as a string
      
      Allowed imports: json, re, math, hashlib, collections, dataclasses, typing, datetime, textwrap, sqlite3, chromadb
      
      ## Runtime Constraints
      
      These limits are enforced during evaluation. Violating them results in score = 0.
      
      - **`read()` output limit**: `kb.read()` must return at most **1000 characters**. Programs that dump all stored text will fail.
      - **`write()` / `read()` timeout**: Each call must complete within **5 seconds**. Avoid expensive computation in these methods.
      - **`toolkit.llm_completion()` budget**: At most **50 LLM calls** per evaluation run. Use LLM calls sparingly in write/read; prefer deterministic retrieval (SQL, text matching) over LLM-based filtering.
      
      ## Instruction Constants (required)
      
      Three module-level string constants provide the natural-language instructions used in task agent prompts:
      
      - INSTRUCTION_OBSERVATION: Instruction for observation generation. Tells the task LLM what to extract and how to structure it. The Observation schema is provided separately — no need to describe field names or types here.
      - INSTRUCTION_QUERY: Instruction for query generation. Tells the task LLM how to formulate retrieval queries. The Query schema is provided separately — no need to describe field names or types here.
      - INSTRUCTION_RESPONSE: Instruction for answer generation. Controls answer format, length, and style.
      
      These are inserted into the task agent prompts as the main directive sentence. They must not be empty.
      
      </interface_spec>
      
      <rules>
      1. Output your diagnosis first, then the complete fixed code in a ```python``` block.
      2. The code must define exactly three classes (Observation, Query, KnowledgeBase) and three module-level string constants (INSTRUCTION_OBSERVATION, INSTRUCTION_QUERY, INSTRUCTION_RESPONSE).
      3. KnowledgeBase.__init__ must accept `toolkit`; write takes an Observation; read takes a Query and returns str.
      4. `read()` must return at most 1000 characters — do not return all stored text.
      5. Keep it simple. Make minimal, targeted fixes.
      6. Update INSTRUCTION_OBSERVATION, INSTRUCTION_QUERY, and INSTRUCTION_RESPONSE to steer the task LLM's output format.
      7. Add clear comments explaining WHY each part of the code works the way it does — this helps future iterations understand and preserve your design decisions.
      </rules>
      
      <current_program iteration="1">
      ```python
      from dataclasses import dataclass, field
      
      INSTRUCTION_OBSERVATION = "Given the following text, create an Observation object to store this information in the knowledge base. Include all key information."
      INSTRUCTION_QUERY = "Given the following question, generate a query to retrieve relevant knowledge."
      INSTRUCTION_RESPONSE = "Based on the above knowledge and the original question, provide a short answer without explanation."
      
      
      @dataclass
      class Observation:
          """Raw text observation to store in the knowledge base."""
          raw: str = field(metadata={"description": "The raw text to store"})
      
      
      @dataclass
      class Query:
          """Raw text query to retrieve from the knowledge base."""
          raw: str = field(metadata={"description": "The query text to search for"})
      
      
      class KnowledgeBase:
          """Simple append-all / return-all knowledge base."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
      
          def write(self, observation: Observation) -> None:
              self.store.append(observation.raw)
              self.toolkit.logger.debug(f"Stored: {observation.raw}")
      
          def read(self, query: Query) -> str:
              self.toolkit.logger.debug(f"Query: {query.raw}, store size: {len(self.store)}")
              if not self.store:
                  return "No information stored."
              result = "\n".join(self.store)
              return result[:1000]
      
      ```
