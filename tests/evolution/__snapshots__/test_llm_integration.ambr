# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      import json
      from dataclasses import dataclass, field
      from typing import Optional, List
      import sqlite3
      import chromadb
      from chromadb.utils import embedding_functions
      
      @dataclass
      class Observation:
          """Structured observation to store in memory."""
          entity: str  # The subject (e.g., "Project Zephyr")
          attribute: str  # The property (e.g., "access code")
          value: str  # The actual information (e.g., "DELTA-7742")
          raw_context: Optional[str] = None  # Optional free text for additional context
      
      @dataclass
      class Query:
          """Query to retrieve information from memory."""
          entity: Optional[str] = None  # Entity to search for
          attribute: Optional[str] = None  # Specific attribute to retrieve
          question: Optional[str] = None  # Natural language question for semantic search
      
      class Memory:
          """Memory system with structured storage and semantic retrieval."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.setup_database()
              self.setup_vector_store()
      
          def setup_database(self):
              """Create structured tables for observations."""
              cursor = self.toolkit.db.cursor()
              cursor.execute("""
                  CREATE TABLE IF NOT EXISTS observations (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      entity TEXT,
                      attribute TEXT,
                      value TEXT,
                      raw_context TEXT,
                      timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
                  )
              """)
              cursor.execute("""
                  CREATE INDEX IF NOT EXISTS idx_entity_attr ON observations(entity, attribute)
              """)
              self.toolkit.db.commit()
      
          def setup_vector_store(self):
              """Initialize Chroma collection for semantic search."""
              try:
                  # ChromaDB from toolkit
                  self.chroma_client = self.toolkit.chroma
                  # Use a simple embedding function (Chroma's default)
                  self.collection = self.chroma_client.get_or_create_collection(
                      name="memory_observations",
                      metadata={"description": "Semantic memory store"}
                  )
              except Exception as e:
                  self.toolkit.logger.log(f"Warning: Chroma setup failed: {e}")
                  self.collection = None
      
          def write(self, observation: Observation) -> None:
              """Store observation in both structured DB and vector store."""
              # Store in SQLite
              cursor = self.toolkit.db.cursor()
              cursor.execute(
                  "INSERT INTO observations (entity, attribute, value, raw_context) VALUES (?, ?, ?, ?)",
                  (observation.entity, observation.attribute, observation.value, observation.raw_context)
              )
              self.toolkit.db.commit()
              
              # Store in Chroma for semantic search
              if self.collection:
                  # Create a combined text for embedding
                  combined_text = f"{observation.entity} {observation.attribute}: {observation.value}"
                  if observation.raw_context:
                      combined_text += f" {observation.raw_context}"
                  
                  # Generate a unique ID
                  import hashlib
                  doc_id = hashlib.md5(combined_text.encode()).hexdigest()
                  
                  self.collection.add(
                      documents=[combined_text],
                      metadatas=[{
                          "entity": observation.entity,
                          "attribute": observation.attribute,
                          "value": observation.value
                      }],
                      ids=[doc_id]
                  )
              
              self.toolkit.logger.log(f"Stored: {observation.entity}.{observation.attribute} = {observation.value}")
      
          def read(self, query: Query) -> str:
              """Retrieve relevant information based on query."""
              self.toolkit.logger.log(f"Query: entity={query.entity}, attribute={query.attribute}, question={query.question}")
              
              results = []
              
              # 1. Try exact match from structured DB first
              if query.entity and query.attribute:
                  cursor = self.toolkit.db.cursor()
                  cursor.execute(
                      "SELECT value FROM observations WHERE entity = ? AND attribute = ?",
                      (query.entity, query.attribute)
                  )
                  exact_matches = cursor.fetchall()
                  if exact_matches:
                      results.extend([match[0] for match in exact_matches])
              
              # 2. Try entity-only match
              if query.entity and not results:
                  cursor = self.toolkit.db.cursor()
                  cursor.execute(
                      "SELECT attribute, value FROM observations WHERE entity = ?",
                      (query.entity,)
                  )
                  entity_matches = cursor.fetchall()
                  if entity_matches:
                      results.extend([f"{attr}: {val}" for attr, val in entity_matches])
              
              # 3. Try semantic search if we have a question and Chroma is available
              if query.question and self.collection and not results:
                  try:
                      chroma_results = self.collection.query(
                          query_texts=[query.question],
                          n_results=3
                      )
                      
                      if chroma_results and chroma_results['documents']:
                          # Extract values from metadata
                          for metadata_list in chroma_results.get('metadatas', []):
                              for metadata in metadata_list:
                                  if metadata and 'value' in metadata:
                                      results.append(metadata['value'])
                  except Exception as e:
                      self.toolkit.logger.log(f"Chroma query error: {e}")
              
              # 4. Return results or default message
              if results:
                  # Remove duplicates while preserving order
                  seen = set()
                  unique_results = []
                  for r in results:
                      if r not in seen:
                          seen.add(r)
                          unique_results.append(r)
                  
                  if len(unique_results) == 1:
                      return unique_results[0]
                  else:
                      return "\n".join([f"- {r}" for r in unique_results])
              else:
                  return "No relevant information found in memory."
    ''',
    'round1_score': 0.0,
    'round2_output': 'The access code for Project Zephyr is DELTA-7742.',
    'round2_score': 1.0,
  })
