# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      from dataclasses import dataclass, field
      from typing import Optional, List
      import sqlite3
      import re
      
      
      @dataclass
      class Observation:
          """Observation to store in memory with structured fields."""
          content: str = field(metadata={"description": "The main content or fact to remember"})
          topic: Optional[str] = field(default=None, metadata={"description": "Topic or subject category (optional)"})
          tags: List[str] = field(default_factory=list, metadata={"description": "Keywords for retrieval"})
      
      
      @dataclass
      class Query:
          """Query to retrieve from memory with search parameters."""
          question: str = field(metadata={"description": "The question or information need"})
          keywords: List[str] = field(default_factory=list, metadata={"description": "Keywords to match against stored content"})
      
      
      class Memory:
          """Memory system using SQLite for storage and basic keyword matching."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db = toolkit.db
              
              # Create table for observations
              self.db.execute("""
                  CREATE TABLE IF NOT EXISTS observations (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      content TEXT NOT NULL,
                      topic TEXT,
                      tags TEXT,
                      created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                  )
              """)
              
              # Create index for faster searches
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_content ON observations(content)")
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_topic ON observations(topic)")
              
              self.toolkit.logger.debug("Memory system initialized with SQLite storage")
      
          def write(self, observation: Observation) -> None:
              """Store an observation in memory."""
              # Convert tags list to comma-separated string for storage
              tags_str = ",".join(observation.tags) if observation.tags else ""
              
              self.db.execute(
                  "INSERT INTO observations (content, topic, tags) VALUES (?, ?, ?)",
                  (observation.content, observation.topic, tags_str)
              )
              self.db.commit()
              
              self.toolkit.logger.debug(f"Stored observation: {observation.content[:80]}...")
      
          def read(self, query: Query) -> str:
              """Retrieve relevant information based on query."""
              self.toolkit.logger.debug(f"Query received: {query.question[:80]}...")
              
              # Extract keywords from query if not provided
              keywords = query.keywords if query.keywords else self._extract_keywords(query.question)
              
              # Search for relevant observations
              results = self._search_memory(keywords, query.question)
              
              if not results:
                  return "No relevant information found."
              
              # Format results for return
              return self._format_results(results)
      
          def _extract_keywords(self, text: str) -> List[str]:
              """Extract potential keywords from text."""
              # Simple keyword extraction: remove common words, split by non-alphanumeric
              common_words = {"the", "a", "an", "is", "are", "what", "where", "when", "who", "how", "why"}
              words = re.findall(r'\b\w+\b', text.lower())
              keywords = [word for word in words if word not in common_words and len(word) > 2]
              return keywords[:5]  # Limit to top 5 keywords
      
          def _search_memory(self, keywords: List[str], question: str) -> List[tuple]:
              """Search memory for relevant observations."""
              if not keywords:
                  # Fallback: search for any mention of question words
                  search_terms = question.split()
              else:
                  search_terms = keywords
              
              # Build OR query for all search terms
              placeholders = ",".join(["?"] * len(search_terms))
              query = f"""
                  SELECT content, topic, tags 
                  FROM observations 
                  WHERE content LIKE '%' || ? || '%'
                  OR topic LIKE '%' || ? || '%'
                  OR tags LIKE '%' || ? || '%'
                  ORDER BY id DESC
                  LIMIT 5
              """
              
              # Execute query for each search term
              all_results = []
              for term in search_terms:
                  cursor = self.db.execute(query, (term, term, term))
                  all_results.extend(cursor.fetchall())
              
              # Remove duplicates while preserving order
              seen = set()
              unique_results = []
              for result in all_results:
                  if result not in seen:
                      seen.add(result)
                      unique_results.append(result)
              
              return unique_results
      
          def _format_results(self, results: List[tuple]) -> str:
              """Format search results into a readable string."""
              if not results:
                  return "No relevant information found."
              
              formatted = []
              for i, (content, topic, tags) in enumerate(results, 1):
                  parts = [f"{i}. {content}"]
                  if topic:
                      parts.append(f"   Topic: {topic}")
                  if tags:
                      parts.append(f"   Tags: {tags}")
                  formatted.append("\n".join(parts))
              
              return "\n\n".join(formatted)
    ''',
    'round1_score': 0.0,
    'round2_output': 'The access code for Project Zephyr is **DELTA-7742**.',
    'round2_score': 1.0,
  })
