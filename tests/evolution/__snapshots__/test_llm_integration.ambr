    'patched_code': '''
      from dataclasses import dataclass, field
      from typing import Optional
      
      INSTRUCTION_KNOWLEDGE_ITEM = (
          "Parse the provided source material and emit JSON with fields "
          "`subject`, `attribute`, `value`, and optional `context`. "
          "Subject names the entity, attribute names the property, "
          "value gives the fact, and context includes supporting details."
      )
      INSTRUCTION_QUERY = (
          "Review the user question and emit JSON with optional `subject`, "
          "`attribute`, and `context` fields reflecting what should be retrieved "
          "from the knowledge base. Empty strings mean the field is not relevant."
      )
      INSTRUCTION_RESPONSE = (
          "Use retrieved knowledge to give a concise, factual answer in sentences "
          "no longer than 100 words. If no knowledge matches, reply with "
          "\"I don't have that information yet.\""
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Knowledge base entries describe factual claims about people, projects, "
          "or processes. Favor direct matches when answering."
       )
      
      
      @dataclass
      class KnowledgeItem:
          """Structured fact to capture in the knowledge base for consistent retrieval."""
          subject: str = field(metadata={"description": "Entity or topic this fact is about"})
          attribute: str = field(metadata={"description": "Property or relationship being described"})
          value: str = field(metadata={"description": "The factual detail being asserted"})
          context: Optional[str] = field(
              default=None,
              metadata={"description": "Optional supporting information or source context"},
          )
      
      
      @dataclass
      class Query:
          """Guides which knowledge items should be retrieved for answering a question."""
          subject: Optional[str] = field(
              default=None, metadata={"description": "Focus entity/topic if present"}
          )
          attribute: Optional[str] = field(
              default=None, metadata={"description": "Property or relationship to filter on"}
          )
          context: Optional[str] = field(
              default=None, metadata={"description": "Contextual hint to narrow results"}
          )
      
      
      class KnowledgeBase:
          """Stores structured facts in SQLite and answers queries via selective filtering."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              # Initialize the facts table; this keeps sciences reproducible and efficient.
              create_table_sql = """
              CREATE TABLE IF NOT EXISTS facts (
                  subject TEXT NOT NULL,
                  attribute TEXT NOT NULL,
                  value TEXT NOT NULL,
                  context TEXT
              )
              """
              toolkit.db.execute(create_table_sql)
              toolkit.db.commit()
      
          def write(self, item: KnowledgeItem) -> None:
              # Persist the structured fact so queries can filter by field values.
              insert_sql = "INSERT INTO facts (subject, attribute, value, context) VALUES (?, ?, ?, ?)"
              self.toolkit.db.execute(
                  insert_sql,
                  (
                      item.subject.strip(),
                      item.attribute.strip(),
                      item.value.strip(),
                      item.context.strip() if item.context else None,
                  ),
              )
              self.toolkit.db.commit()
              self.toolkit.logger.debug(f"Stored fact: {item.subject} | {item.attribute} -> {item.value}")
      
          def read(self, query: Query) -> str:
              self.toolkit.logger.debug(
                  "Read query",
                  extra={
                      "subject": query.subject,
                      "attribute": query.attribute,
                      "context": query.context,
                  },
              )
              filters = []
              params = []
              # Build a case-insensitive WHERE clause by adding lower() comparisons.
              if query.subject:
                  filters.append("LOWER(subject) = LOWER(?)")
                  params.append(query.subject)
              if query.attribute:
                  filters.append("LOWER(attribute) = LOWER(?)")
                  params.append(query.attribute)
              if query.context:
                  filters.append("context LIKE ?")
                  params.append(f"%{query.context}%")
      
              where_clause = f"WHERE {' AND '.join(filters)}" if filters else ""
              select_sql = f"SELECT subject, attribute, value, context FROM facts {where_clause} ORDER BY rowid DESC LIMIT 5"
              cursor = self.toolkit.db.execute(select_sql, params)
              rows = cursor.fetchall()
      
              if not rows:
                  self.toolkit.logger.debug("No matching facts found.")
                  return "I don't have that information yet."
      
              summary_lines = []
              for subject, attribute, value, context in rows:
                  line = f"{subject} · {attribute}: {value}"
                  if context:
                      line += f" (context: {context})"
                  summary_lines.append(line)
      
              response = "\n".join(summary_lines)
              # Always enforce the 1000-character hard cap on read responses.
              self.toolkit.logger.debug(f"Responding with {len(response)} characters")
              return response[:1000]
  
    ''',
    'prompt': '''
