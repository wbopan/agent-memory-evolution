# name: test_runtime_violation_fix_oversized_read
  dict({
    'fixed_code': '''
      from dataclasses import dataclass
      
      INSTRUCTION_KNOWLEDGE_ITEM = "Extract concise, factual knowledge from the provided source text."
      INSTRUCTION_QUERY = "Formulate a focused retrieval query for relevant knowledge."
      INSTRUCTION_RESPONSE = "Respond clearly and concisely using only relevant retrieved knowledge."
      ALWAYS_ON_KNOWLEDGE = ""
      
      
      @dataclass
      class KnowledgeItem:
          raw: str
      
      
      @dataclass
      class Query:
          raw: str
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
      
          def write(self, item: KnowledgeItem, raw_text: str = "") -> None:
              self.store.append(item.raw)
      
          def read(self, query: Query) -> str:
              return "\n".join(self.store)[:3000]
  
    ''',
    'runtime_violation': 'kb.read() returned 5000 chars (limit: 3000)',
  })
