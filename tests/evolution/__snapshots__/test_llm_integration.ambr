  dict({
    'fixed_code': '''
      from dataclasses import dataclass, field
      
      INSTRUCTION_KNOWLEDGE_ITEM = "Extract task-relevant knowledge and record it using the KnowledgeItem schema; respond with valid JSON that matches the schema exactly."
      INSTRUCTION_QUERY = "Formulate a concise Query JSON object describing the information needed from the knowledge base."
      INSTRUCTION_RESPONSE = "When answering, be helpful, concise, and cite relevant stored knowledge briefly."
      ALWAYS_ON_KNOWLEDGE = "Always reference stored knowledge items accurately and avoid inventing details."
      
      
      @dataclass
      class KnowledgeItem:
          raw: str = field(metadata={"description": "Original text that represents a piece of knowledge to store."})
      
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "Text describing what information to retrieve from the knowledge base."})
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
      
          def write(self, item: KnowledgeItem) -> None:
              self.store.append(item.raw)
      
          def read(self, query: Query) -> str:
              combined = "\n".join(self.store)
              result = combined[-1000:]
              self.toolkit.logger.debug(f"Returning {len(result)} chars for query {query.raw!r}.")
              return result
  
    ''',
    'runtime_violation': 'kb.read() returned 5000 chars (limit: 1000)',
