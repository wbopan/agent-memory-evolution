      from dataclasses import dataclass, field
      from typing import Optional, List
      import json
      import sqlite3
      import chromadb
      from datetime import datetime
      
      INSTRUCTION_OBSERVATION = "Capture relevant information from your observations in a structured format. Focus on key facts, entities, and relationships that would be useful for future reference."
      INSTRUCTION_QUERY = "Formulate specific queries to retrieve relevant information from the knowledge base. Include clear parameters and context to help narrow down the search."
      INSTRUCTION_RESPONSE = "Provide concise, relevant answers based on the retrieved information. Keep responses focused and under 1000 characters. Include only the most pertinent information."
      
      
      @dataclass
      class Observation:
          content: str = field(metadata={"description": "The main content or observation to store"})
          category: Optional[str] = field(default=None, metadata={"description": "Optional category for classification"})
          tags: List[str] = field(default_factory=list, metadata={"description": "List of tags for organization and search"})
          source: Optional[str] = field(default=None, metadata={"description": "Optional source identifier"})
          timestamp: str = field(default_factory=lambda: datetime.now().isoformat(), metadata={"description": "ISO format timestamp of when the observation was made"})
          importance: int = field(default=1, metadata={"description": "Importance level from 1 (low) to 5 (high)"})
      
      
      @dataclass
      class Query:
          search_text: str = field(metadata={"description": "Text to search for in the knowledge base"})
          category_filter: Optional[str] = field(default=None, metadata={"description": "Optional category to filter results"})
          min_importance: int = field(default=1, metadata={"description": "Minimum importance level (1-5)"})
          tags: List[str] = field(default_factory=list, metadata={"description": "Tags to filter by (all must match)"})
          max_results: int = field(default=5, metadata={"description": "Maximum number of results to return"})
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.logger = toolkit.logger
              
              # Create SQLite table for structured data
              self.toolkit.db.execute("""
                  CREATE TABLE IF NOT EXISTS observations (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      content TEXT NOT NULL,
                      category TEXT,
                      tags TEXT,
                      source TEXT,
                      timestamp TEXT,
                      importance INTEGER,
                      embedding_id TEXT
                  )
              """)
              
              # Create Chroma collection for embeddings
              self.collection = self.toolkit.chroma.create_collection(name="knowledge_base")
              
              self.logger.debug("KnowledgeBase initialized")
      
          def write(self, observation: Observation) -> None:
              # Store in SQLite
              tags_json = json.dumps(observation.tags)
              
              cursor = self.toolkit.db.execute("""
                  INSERT INTO observations (content, category, tags, source, timestamp, importance)
                  VALUES (?, ?, ?, ?, ?, ?)
              """, (observation.content, observation.category, tags_json, 
                    observation.source, observation.timestamp, observation.importance))
              
              # Get the inserted ID
              obs_id = cursor.lastrowid
              
              # Create embedding and store in Chroma
              embedding_id = f"obs_{obs_id}"
              
              # Generate embedding using LLM (simplified - in practice would use embedding model)
              # For simplicity, we'll store a basic representation
              text_to_embed = f"{observation.content} {observation.category or ''} {' '.join(observation.tags)}"
              
              self.collection.add(
                  ids=[embedding_id],
                  documents=[text_to_embed],
                  metadatas=[{
                      "id": obs_id,
                      "category": observation.category or "",
                      "importance": observation.importance
                  }]
              )
              
              # Update SQLite with embedding ID
              self.toolkit.db.execute(
                  "UPDATE observations SET embedding_id = ? WHERE id = ?",
                  (embedding_id, obs_id)
              )
              
              self.logger.debug(f"Observation written with ID {obs_id}")
      
          def read(self, query: Query) -> str:
              # First, try to find relevant observations using Chroma
              if query.search_text:
                  try:
                      results = self.collection.query(
                          query_texts=[query.search_text],
                          n_results=min(query.max_results, 10),
                          where={"importance": {"$gte": query.min_importance}} if query.min_importance > 1 else None
                      )
                      
                      if results['ids'] and results['ids'][0]:
                          # Get IDs from Chroma results
                          chroma_ids = results['ids'][0]
                          obs_ids = [int(id.split('_')[1]) for id in chroma_ids if id.startswith('obs_')]
                          
                          if obs_ids:
                              # Fetch full records from SQLite
                              placeholders = ','.join(['?'] * len(obs_ids))
                              sql_query = f"""
                                  SELECT content, category, timestamp, importance 
                                  FROM observations 
                                  WHERE id IN ({placeholders})
                              """
                              
                              # Apply additional filters
                              filters = []
                              params = list(obs_ids)
                              
                              if query.category_filter:
                                  filters.append("category = ?")
                                  params.append(query.category_filter)
                              
                              if query.tags:
                                  # For each tag, check if it exists in the JSON array
                                  for tag in query.tags:
                                      filters.append("tags LIKE ?")
                                      params.append(f'%"{tag}"%')
                              
                              if filters:
                                  sql_query += " AND " + " AND ".join(filters)
                              
                              sql_query += " ORDER BY importance DESC, timestamp DESC LIMIT ?"
                              params.append(query.max_results)
                              
                              cursor = self.toolkit.db.execute(sql_query, params)
                              results_data = cursor.fetchall()
                              
                              if results_data:
                                  response_parts = []
                                  for content, category, timestamp, importance in results_data:
                                      response_parts.append(f"[{category or 'Uncategorized'}] {content}")
                                  
                                  response = "\n".join(response_parts)
                                  if len(response) > 1000:
                                      response = response[:997] + "..."
                                  return response
                  except Exception as e:
                      self.logger.debug(f"Chroma search failed: {e}")
              
              # Fallback to SQLite-only search
              filters = ["importance >= ?"]
              params = [query.min_importance]
              
              if query.search_text:
                  filters.append("content LIKE ?")
                  params.append(f"%{query.search_text}%")
              
              if query.category_filter:
                  filters.append("category = ?")
                  params.append(query.category_filter)
              
              if query.tags:
                  for tag in query.tags:
                      filters.append("tags LIKE ?")
                      params.append(f'%"{tag}"%')
              
              where_clause = " AND ".join(filters)
              sql_query = f"""
                  SELECT content, category, timestamp, importance 
                  FROM observations 
                  WHERE {where_clause}
                  ORDER BY importance DESC, timestamp DESC 
                  LIMIT ?
              """
              params.append(query.max_results)
              
              cursor = self.toolkit.db.execute(sql_query, params)
              results = cursor.fetchall()
              
              if results:
                  response_parts = []
                  for content, category, timestamp, importance in results:
                      response_parts.append(f"[{category or 'Uncategorized'}] {content}")
                  
                  response = "\n".join(response_parts)
                  if len(response) > 1000:
                      response = response[:997] + "..."
                  return response
              else:
                  response = "No relevant information found in the knowledge base."
                  if len(response) > 1000:
                      response = response[:997] + "..."
                  return response
    ''',
