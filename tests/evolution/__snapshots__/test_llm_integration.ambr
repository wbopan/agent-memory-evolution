# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      import hashlib
      import re
      from dataclasses import dataclass, field
      from typing import Optional
      
      INSTRUCTION_KNOWLEDGE_ITEM = (
          "Extract durable, atomic facts from the source text. Prefer one clear fact per item: "
          "who/what (subject), which property (attribute), and the exact value. "
          "Keep values verbatim when they look like identifiers, codes, numbers, or names. "
          "Do not add speculation; if uncertain, leave fields minimal but factual."
      )
      INSTRUCTION_QUERY = (
          "Turn the user question into a focused retrieval query. Preserve the original question, "
          "identify the main entity (if any), the requested property (if any), and useful keywords "
          "that improve matching. Keep keywords short and literal."
      )
      INSTRUCTION_RESPONSE = (
          "Answer directly using retrieved memory. If a precise value is present, output it exactly. "
          "Be concise and avoid unrelated details. If memory is insufficient, clearly say so."
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Knowledge-base strategy: store and retrieve facts as subject-attribute-value triples with "
          "supporting text. Prioritize exact identifiers (codes, IDs, names, dates). During retrieval, "
          "match both semantics and literal tokens; entity/property matches are high priority. "
          "When evidence exists, answer confidently and directly from memory rather than defaulting to "
          "'unknown'. Keep outputs short and high-signal."
      )
      
      
      @dataclass
      class KnowledgeItem:
          """Structured fact for durable retrieval across paraphrases and direct questions."""
          subject: str = field(
              default="",
              metadata={"description": "Main entity/topic the fact is about (e.g., Project Zephyr)."},
          )
          attribute: str = field(
              default="",
              metadata={"description": "Property of the subject (e.g., access code, owner, deadline)."},
          )
          value: str = field(
              default="",
              metadata={"description": "Exact value for the attribute (e.g., DELTA-7742)."},
          )
          statement: str = field(
              default="",
              metadata={"description": "Short supporting sentence capturing the fact in natural language."},
          )
          keywords: list[str] = field(
              default_factory=list,
              metadata={"description": "Important literal tokens for retrieval (names, codes, terms)."},
          )
          source_hint: Optional[str] = field(
              default=None,
              metadata={"description": "Optional short provenance hint like document title/section."},
          )
      
      
      @dataclass
      class Query:
          """Focused retrieval query with optional entity/property hints."""
          raw_question: str = field(
              default="",
              metadata={"description": "Original user question, preserved verbatim."},
          )
          focus_entity: Optional[str] = field(
              default=None,
              metadata={"description": "Primary entity the question asks about, if identifiable."},
          )
          focus_attribute: Optional[str] = field(
              default=None,
              metadata={"description": "Requested property/value type, if identifiable."},
          )
          keywords: list[str] = field(
              default_factory=list,
              metadata={"description": "Short list of key tokens to aid retrieval."},
          )
      
      
      class KnowledgeBase:
          """SQLite-backed fact memory with lightweight lexical ranking.
      
          Design goals:
          - Store structured facts (subject/attribute/value) for precise QA.
          - Keep retrieval deterministic, fast, and transparent.
          - Return compact evidence snippets (<=1000 chars) for the task agent.
          """
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db = toolkit.db
              # Why SQLite: simple, durable per-run storage and easy filtering/ranking input.
              self.db.execute(
                  """
                  CREATE TABLE IF NOT EXISTS facts (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      subject TEXT,
                      attribute TEXT,
                      value TEXT,
                      statement TEXT,
                      keywords TEXT,
                      source_hint TEXT,
                      raw_text TEXT,
                      fingerprint TEXT UNIQUE
                  )
                  """
              )
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_facts_subject ON facts(subject)")
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_facts_attribute ON facts(attribute)")
              self.db.commit()
              self.toolkit.logger.debug("KnowledgeBase initialized with facts table.")
      
          def _tokenize(self, text: str) -> list[str]:
              """Small tokenizer for robust lexical overlap scoring."""
              if not text:
                  return []
              return re.findall(r"[A-Za-z0-9\-_/]+", text.lower())
      
          def write(self, item: KnowledgeItem, raw_text: str) -> None:
              # Build a stable canonical representation to deduplicate repeated writes.
              subject = (item.subject or "").strip()
              attribute = (item.attribute or "").strip()
              value = (item.value or "").strip()
              statement = (item.statement or "").strip()
              source_hint = (item.source_hint or "").strip() or None
      
              # Why fallback logic: extraction can be partial; raw_text preserves usable evidence.
              if not statement:
                  parts = [p for p in [subject, attribute, value] if p]
                  statement = " | ".join(parts) if parts else (raw_text or "").strip()
      
              keywords = [k.strip() for k in (item.keywords or []) if k and k.strip()]
              if not keywords:
                  # Auto-keywords keep retrieval resilient when writer omits keyword field.
                  seen = set()
                  for tok in self._tokenize(" ".join([subject, attribute, value, statement]))[:12]:
                      if tok not in seen:
                          seen.add(tok)
                          keywords.append(tok)
      
              key_material = "\n".join([subject, attribute, value, statement, "|".join(keywords)])
              fingerprint = hashlib.sha1(key_material.encode("utf-8")).hexdigest()
      
              self.db.execute(
                  """
                  INSERT OR IGNORE INTO facts
                  (subject, attribute, value, statement, keywords, source_hint, raw_text, fingerprint)
                  VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                  """,
                  (
                      subject,
                      attribute,
                      value,
                      statement,
                      ",".join(keywords),
                      source_hint,
                      (raw_text or "").strip(),
                      fingerprint,
                  ),
              )
              self.db.commit()
              self.toolkit.logger.debug(
                  f"Stored fact: subject='{subject[:40]}', attribute='{attribute[:40]}', value='{value[:40]}'"
              )
      
          def read(self, query: Query) -> str:
              raw_q = (query.raw_question or "").strip()
              focus_entity = (query.focus_entity or "").strip().lower()
              focus_attribute = (query.focus_attribute or "").strip().lower()
              q_keywords = [k.strip().lower() for k in (query.keywords or []) if k and k.strip()]
      
              q_text = " ".join([raw_q] + q_keywords).strip()
              q_tokens = set(self._tokenize(q_text))
              if focus_entity:
                  q_tokens.update(self._tokenize(focus_entity))
              if focus_attribute:
                  q_tokens.update(self._tokenize(focus_attribute))
      
              rows = self.db.execute(
                  """
                  SELECT subject, attribute, value, statement, keywords, source_hint, raw_text
                  FROM facts
                  """
              ).fetchall()
              self.toolkit.logger.debug(f"Read query='{raw_q[:80]}', candidate_facts={len(rows)}")
              if not rows:
                  return "No relevant information found in memory."
      
              scored = []
              for r in rows:
                  subject, attribute, value, statement, keywords, source_hint, raw_text = r
                  blob = " ".join(
                      [
                          subject or "",
                          attribute or "",
                          value or "",
                          statement or "",
                          keywords or "",
                          source_hint or "",
                          raw_text or "",
                      ]
                  ).lower()
                  rtoks = set(self._tokenize(blob))
                  overlap = len(q_tokens & rtoks)
                  score = float(overlap)
      
                  # Entity/property boosts strongly help direct fact lookups.
                  if focus_entity and focus_entity in blob:
                      score += 4.0
                  if focus_attribute and focus_attribute in blob:
                      score += 3.0
                  if raw_q and raw_q.lower() in blob:
                      score += 2.0
                  if value and value.lower() in raw_q.lower():
                      score += 0.5
      
                  scored.append((score, r))
      
              scored.sort(key=lambda x: x[0], reverse=True)
              top = [r for s, r in scored[:6] if s > 0]
              if not top:
                  # Fallback: return a tiny sample rather than hard-failing, useful for sparse queries.
                  top = [r for _, r in scored[:2]]
      
              lines: list[str] = []
              for subject, attribute, value, statement, keywords, source_hint, _raw_text in top:
                  # Why this format: concise, answer-oriented, and easy for downstream agent parsing.
                  fact = f"{subject} | {attribute} | {value}".strip(" |")
                  support = statement or ""
                  line = f"- {fact}"
                  if support and support.lower() not in fact.lower():
                      line += f" :: {support}"
                  if source_hint:
                      line += f" (src: {source_hint})"
                  lines.append(line[:220])
      
              result = "Relevant memory:\n" + "\n".join(lines)
              return result[:1000]
  
    ''',
    'round1_score': 0.0,
    'round2_output': 'DELTA-7742',
    'round2_score': 1.0,
  })
