# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      from dataclasses import dataclass, field
      import re
      
      # These instructions are consumed by upstream task agents.
      # Keep them short, explicit, and non-empty so the LLM reliably produces useful JSON.
      INSTRUCTION_OBSERVATION = (
          "Extract concrete, self-contained facts from the source text. "
          "Preserve exact names, identifiers, codes, and numbers verbatim."
      )
      INSTRUCTION_QUERY = (
          "Write a focused retrieval query using the key entities and requested fact."
      )
      INSTRUCTION_RESPONSE = (
          "Answer using only retrieved memory. Be concise and include exact values when present."
      )
      
      
      @dataclass
      class Observation:
          """Single memory item to store."""
          raw: str = field(
              metadata={
                  "description": "A standalone factual statement to store verbatim."
              }
          )
      
      
      @dataclass
      class Query:
          """Text query used to retrieve relevant memories."""
          raw: str = field(
              metadata={
                  "description": "Natural-language question or lookup text for retrieval."
              }
          )
      
      
      class KnowledgeBase:
          """Simple lexical-memory KB.
      
          Design goal: deterministic, fast retrieval with no LLM calls in write/read.
          This avoids budget/latency issues and is robust for exact-fact Q&A.
          """
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
              self._debug("KnowledgeBase initialized.")
      
          def _debug(self, message: str) -> None:
              """Best-effort debug logging.
      
              WHY: Interface promises logger.debug(), but a safe fallback prevents
              accidental runtime failures if a different logger shape is provided.
              """
              logger = getattr(self.toolkit, "logger", None)
              if logger is None:
                  return
              if hasattr(logger, "debug"):
                  logger.debug(message)
              elif hasattr(logger, "log"):
                  logger.log(message)
      
          def _tokens(self, text: str) -> set[str]:
              """Normalize text for lightweight lexical scoring."""
              return set(re.findall(r"[a-z0-9]+", (text or "").lower()))
      
          def write(self, observation: Observation) -> None:
              # WHY: ignore empty writes to keep memory cleaner and retrieval sharper.
              text = (observation.raw or "").strip()
              if not text:
                  self._debug("Skipped empty observation.")
                  return
              self.store.append(text)
              self._debug(f"Stored observation #{len(self.store)}: {text[:120]}")
      
          def read(self, query: Query) -> str:
              q = (query.raw or "").strip()
              self._debug(f"Read query: {q[:120]} | store size={len(self.store)}")
              if not self.store:
                  return "No information stored."
      
              q_tokens = self._tokens(q)
              scored: list[tuple[int, int, str]] = []
              q_lower = q.lower()
      
              # WHY: token overlap is cheap and effective for factual lookup; we also
              # add a substring bonus for near-exact matches.
              for idx, item in enumerate(self.store):
                  item_tokens = self._tokens(item)
                  overlap = len(q_tokens & item_tokens)
                  bonus = 3 if q_lower and q_lower in item.lower() else 0
                  score = overlap + bonus
                  if score > 0:
                      scored.append((score, idx, item))
      
              if not scored:
                  # WHY: if lexical match fails, return recent context rather than
                  # claiming empty memory; this still gives the answering model signal.
                  fallback = self.store[-3:]
                  result = "\n".join(f"- {x}" for x in fallback)
                  return result[:1000]
      
              # Higher score first; for ties prefer newer entries.
              scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
              top_items = [item for _, _, item in scored[:3]]
              result = "\n".join(f"- {x}" for x in top_items)
              return result[:1000]
  
    ''',
    'round1_score': 0.0,
    'round2_output': 'Project Zephyr’s access code is DELTA-7742.',
    'round2_score': 1.0,
  })
