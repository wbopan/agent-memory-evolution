    'patched_code': '''
      from dataclasses import dataclass, field
      from typing import Optional
      
      INSTRUCTION_OBSERVATION = (
          "Extract a single factual statement from the input and describe it with subject, predicate, value, "
          "and an optional source for provenance. Provide the result as JSON matching the Observation schema."
      )
      INSTRUCTION_QUERY = (
          "Interpret the question and produce the most relevant retrieval hints using the Query schema, "
          "focusing on subject, predicate, and optional detail keywords that would help narrow the search."
      )
      INSTRUCTION_RESPONSE = (
          "Answer succinctly using the retrieved facts. Mention the most relevant fact and cite its source when possible; "
          "if no fact matches, reply with 'I don't know'. Keep the answer concise and under 1000 characters."
      )
      
      
      @dataclass
      class Observation:
          """Structured fact stored in the knowledge base for reliable retrieval."""
          subject: str = field(
              metadata={"description": "The primary entity, person, or thing described by this fact."}
          )
          predicate: str = field(
              metadata={"description": "The relationship or attribute connecting the subject to the value."}
          )
          value: str = field(metadata={"description": "The object, detail, or answer that completes the fact."})
          source: Optional[str] = field(
              default=None,
              metadata={"description": "Optional provenance such as document title or timestamp."},
          )
      
      
      @dataclass
      class Query:
          """Structured hints used to filter stored observations when answering questions."""
          subject: Optional[str] = field(
              default=None, metadata={"description": "The main entity or topic to look up."}
          )
          predicate: Optional[str] = field(
              default=None,
              metadata={"description": "A specific attribute, relationship, or question focus to filter by."},
          )
          detail: Optional[str] = field(
              default=None,
              metadata={"description": "Additional keywords that might appear in the observation value."},
          )
      
      
      class KnowledgeBase:
          """Simple append-all / return-all knowledge base."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db = toolkit.db
              # Create a lightweight facts table so we can filter by subject/predicate/value quickly.
              self.db.execute(
                  """
                  CREATE TABLE IF NOT EXISTS facts (
                      subject TEXT NOT NULL,
                      predicate TEXT NOT NULL,
                      value TEXT NOT NULL,
                      source TEXT
                  )
                  """
              )
              # Logging here helps trace whether initialization succeeded during diagnosis.
              self.toolkit.logger.debug("KnowledgeBase initialized with facts table.")
      
          def write(self, observation: Observation) -> None:
              # Persist each structured fact immediately to keep the database in sync with writes.
              with self.db:
                  self.db.execute(
                      "INSERT INTO facts (subject, predicate, value, source) VALUES (?, ?, ?, ?)",
                      (observation.subject, observation.predicate, observation.value, observation.source),
                  )
              self.toolkit.logger.debug(
                  "Stored fact",
                  extra={
                      "subject": observation.subject,
                      "predicate": observation.predicate,
                      "value": observation.value,
                      "source": observation.source,
                  },
              )
      
          def read(self, query: Query) -> str:
              # Build WHERE clauses that respect the structured Query fields so we return targeted facts.
              filters = []
              params = []
              if query.subject:
                  filters.append("subject LIKE ?")
                  params.append(f"%{query.subject}%")
              if query.predicate:
                  filters.append("predicate LIKE ?")
                  params.append(f"%{query.predicate}%")
              if query.detail:
                  filters.append("value LIKE ?")
                  params.append(f"%{query.detail}%")
              sql = "SELECT subject, predicate, value, source FROM facts"
              if filters:
                  sql += " WHERE " + " AND ".join(filters)
              sql += " ORDER BY rowid DESC LIMIT 8"
              rows = self.db.execute(sql, params).fetchall()
              if not rows:
                  self.toolkit.logger.debug("Query returned no matching facts", extra={"query": query})
                  return "No matching facts found."
      
              lines = []
              for subject, predicate, value, source in rows:
                  line = f"{subject} {predicate} {value}"
                  if source:
                      line += f" (source: {source})"
                  lines.append(line)
              result = "\n".join(lines)
              if len(result) > 1000:
                  result = result[:997] + "..."
              self.toolkit.logger.debug(
                  "Query result prepared",
                  extra={"query": query, "result_length": len(result)},
              )
              return result
  
    ''',
