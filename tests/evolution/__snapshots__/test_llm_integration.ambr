    'patched_code': '''
      from dataclasses import dataclass, field
      from typing import Optional
      import sqlite3
      
      INSTRUCTION_OBSERVATION = (
          "When observing a fact, break it into subject, predicate, object, and optional context. "
          "Return a JSON object matching the Observation schema, focusing on explicit assertions. "
          "If a sentence says 'Alice likes blue', set subject='Alice', predicate='likes', object='blue'."
      )
      INSTRUCTION_QUERY = (
          "Translate the user question into a structured query using subject, predicate, and keywords. "
          "Prefer exact subjects/predicates when mentioned; fall back to keywords when necessary."
      )
      INSTRUCTION_RESPONSE = (
          "Answer concisely by quoting at most the few facts that directly support the query, "
          "and keep the response under 1000 characters. Do not add extra explanation."
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Remember that every observation is structured as subject/predicate/object/context, "
          "and queries should filter those fields rather than returning the entire store."
      )
      
      
      @dataclass
      class Observation:
          """Observation broken into structured fact components."""
          subject: str = field(
              metadata={"description": "Entity or actor that the fact is about"}
          )
          predicate: str = field(
              metadata={"description": "Relationship or attribute that connects subject to object"}
          )
          object: str = field(
              metadata={"description": "Thing that completes the fact about the subject"}
          )
          context: Optional[str] = field(
              default=None,
              metadata={"description": "Optional additional context (scene, time, nuance) for the fact"},
          )
      
      
      @dataclass
      class Query:
          """Structured query parameters for retrieving stored facts."""
          subject: Optional[str] = field(
              default=None,
              metadata={"description": "Subject to search for (use None if any subject is acceptable)"},
          )
          predicate: Optional[str] = field(
              default=None,
              metadata={"description": "Predicate to search for if mentioned in the question"},
          )
          keywords: Optional[str] = field(
              default=None,
              metadata={"description": "Supplementary keywords to fuzzy-match against any field"},
          )
      
      
      class KnowledgeBase:
          """Simple append-all / return-all knowledge base."""
      
          def __init__(self, toolkit):
              # Store references to toolkit components for reuse and logging
              self.toolkit = toolkit
              self.db: sqlite3.Connection = toolkit.db
              # Ensure the table exists so we can write/read structured observations
              self._ensure_table()
      
          def write(self, observation: Observation) -> None:
              # Persist the structured observation so we can filter by field later
              with self.db:
                  self.db.execute(
                      """
                      INSERT INTO observations (subject, predicate, object, context)
                      VALUES (?, ?, ?, ?)
                      """,
                      (
                          observation.subject,
                          observation.predicate,
                          observation.object,
                          observation.context,
                      ),
                  )
              self.toolkit.logger.debug(
                  f"Stored observation: {observation.subject} {observation.predicate} {observation.object}"
              )
      
          def read(self, query: Query) -> str:
              # Build dynamic SQL filters based on which query fields are present
              filters = []
              params = []
              if query.subject:
                  filters.append("subject LIKE ?")
                  params.append(f"%{query.subject}%")
              if query.predicate:
                  filters.append("predicate LIKE ?")
                  params.append(f"%{query.predicate}%")
              if query.keywords:
                  for keyword in query.keywords.split():
                      filters.append(
                          "(subject LIKE ? OR predicate LIKE ? OR object LIKE ? OR context LIKE ?)"
                      )
                      params.extend([f"%{keyword}%"] * 4)
              where_clause = " AND ".join(filters) if filters else "1"
      
              self.toolkit.logger.debug(f"Running read with filters={filters}, params={params}")
      
              cursor = self.db.execute(
                  f"""
                  SELECT subject, predicate, object, context
                  FROM observations
                  WHERE {where_clause}
                  ORDER BY rowid DESC
                  LIMIT 5
                  """,
                  params,
              )
              rows = cursor.fetchall()
              if not rows:
                  return "No matching information stored."
      
              # Format each matching fact clearly and slice to stay under 1000 characters
              formatted = []
              for subject, predicate, obj, context in rows:
                  context_text = context if context else "context not provided"
                  formatted.append(f"{subject} {predicate} {obj}. Context: {context_text}")
      
              response = "\n".join(formatted)
              return response[:1000]
      
          def _ensure_table(self) -> None:
              """Create the observations table if it doesn't exist yet."""
              with self.db:
                  self.db.execute(
                      """
                      CREATE TABLE IF NOT EXISTS observations (
                          id INTEGER PRIMARY KEY AUTOINCREMENT,
                          subject TEXT NOT NULL,
                          predicate TEXT NOT NULL,
                          object TEXT NOT NULL,
                          context TEXT
                      )
                      """
                  )
  
    ''',
