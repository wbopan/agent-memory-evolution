  dict({
    'reflected_code': '''
      import json
      import re
      from dataclasses import dataclass, field
      from typing import Optional
      
      INSTRUCTION_KNOWLEDGE_ITEM = (
          "Extract ONE atomic, verifiable fact from the source text. Preserve exact spellings, "
          "codes, IDs, numbers, and dates. If the text contains a clear value that directly answers "
          "a likely question (e.g., an access code, owner, deadline), put that exact value in answer. "
          "Include compact retrieval keywords (entity names, key nouns, unique terms)."
      )
      
      INSTRUCTION_QUERY = (
          "Convert the user request into a retrieval-friendly query. Keep the full question, add a short "
          "focus entity/topic when obvious, and include precise keywords that should match stored facts. "
          "Prefer concrete identifiers and proper nouns over vague words."
      )
      
      INSTRUCTION_RESPONSE = (
          "Answer using retrieved memory only. Give the shortest correct answer first, preserving exact "
          "identifiers/codes. If evidence is insufficient, explicitly say so instead of guessing."
      )
      
      ALWAYS_ON_KNOWLEDGE = (
          "Memory-grounded behavior rules:\n"
          "1) Prefer exact literal values from memory over paraphrases (especially codes/IDs/numbers).\n"
          "2) For 'What is X' questions, look for key-value style facts and return the value directly.\n"
          "3) Treat retrieved snippets as evidence; do not invent missing facts.\n"
          "4) When uncertain, state insufficiency clearly.\n"
          "5) Keep answers concise, but never alter alphanumeric identifiers."
      )
      
      
      @dataclass
      class KnowledgeItem:
          """
          Structured fact record.
          This schema gives retrieval more signal than raw text alone while staying JSON-compatible.
          """
      
          fact: str = field(
              metadata={
                  "description": "One standalone factual statement captured from the text; keep exact wording for critical values."
              }
          )
          answer: Optional[str] = field(
              default=None,
              metadata={
                  "description": "Direct short answer value if explicitly present (e.g., DELTA-7742); otherwise null."
              },
          )
          subject: Optional[str] = field(
              default=None,
              metadata={
                  "description": "Main entity/topic this fact is about (project/person/system), if clear."
              },
          )
          keywords: list[str] = field(
              default_factory=list,
              metadata={
                  "description": "3-12 short retrieval keywords: entities, nouns, and unique terms from the fact."
              },
          )
      
      
      @dataclass
      class Query:
          """
          Retrieval query with both natural-language intent and sparse keywords.
          """
      
          question: str = field(
              metadata={"description": "User question in full, minimally rewritten for clarity."}
          )
          keywords: list[str] = field(
              default_factory=list,
              metadata={"description": "Important retrieval terms: entities, identifiers, and key nouns."},
          )
          focus: Optional[str] = field(
              default=None,
              metadata={"description": "Primary entity/topic being asked about, if any."},
          )
      
      
      class KnowledgeBase:
          """
          SQLite-backed knowledge base with lightweight lexical ranking + one-call LLM synthesis.
      
          Design rationale:
          - Writes store structured fields for better recall than plain blobs.
          - Reads score overlap between query terms and stored terms to shortlist evidence quickly.
          - A single LLM call then synthesizes concise, memory-grounded output for downstream answering.
          """
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db = toolkit.db
              self.db.execute(
                  """
                  CREATE TABLE IF NOT EXISTS kb_items (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      fact TEXT NOT NULL,
                      answer TEXT,
                      subject TEXT,
                      keywords_json TEXT NOT NULL,
                      raw_text TEXT NOT NULL
                  )
                  """
              )
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_kb_items_id ON kb_items(id)")
              self.db.commit()
              self._debug("KnowledgeBase initialized with table kb_items")
      
          def _debug(self, message: str) -> None:
              """Use debug logging when available; gracefully fallback for logger variants."""
              logger = getattr(self.toolkit, "logger", None)
              if logger is None:
                  return
              if hasattr(logger, "debug"):
                  logger.debug(message)
              elif hasattr(logger, "log"):
                  logger.log(message)
      
          def _normalize_text(self, text: str) -> str:
              text = (text or "").lower()
              text = re.sub(r"[^a-z0-9\- ]+", " ", text)
              return re.sub(r"\s+", " ", text).strip()
      
          def _tokenize(self, text: str) -> list[str]:
              # Keep hyphenated/alphanumeric tokens (useful for IDs like DELTA-7742).
              return re.findall(r"[A-Za-z0-9\-]{2,}", (text or "").lower())
      
          def write(self, item: KnowledgeItem, raw_text: str) -> None:
              """
              Store one normalized fact row.
              Why this works: dedup + keywords improves retrieval quality while keeping writes cheap.
              """
              fact = (item.fact or "").strip() or (raw_text or "").strip()
              if not fact:
                  self._debug("write skipped: empty fact and empty raw_text")
                  return
      
              answer = (item.answer or "").strip() or None
              subject = (item.subject or "").strip() or None
      
              # Merge provided keywords with tokens extracted from salient fields.
              seen = set()
              keywords: list[str] = []
              for kw in (item.keywords or []):
                  norm = self._normalize_text(kw)
                  if norm and norm not in seen:
                      seen.add(norm)
                      keywords.append(norm)
              for tok in self._tokenize(" ".join([fact, subject or "", answer or ""])):
                  if tok not in seen:
                      seen.add(tok)
                      keywords.append(tok)
              keywords = keywords[:40]
      
              # Simple deduplication prevents repeated inserts of identical facts.
              existing = self.db.execute(
                  "SELECT id FROM kb_items WHERE fact = ? AND IFNULL(answer, '') = IFNULL(?, '') LIMIT 1",
                  (fact, answer),
              ).fetchone()
              if existing:
                  self._debug(f"write dedup: existing row id={existing[0]} fact={fact[:80]}")
                  return
      
              cursor = self.db.execute(
                  "INSERT INTO kb_items (fact, answer, subject, keywords_json, raw_text) VALUES (?, ?, ?, ?, ?)",
                  (
                      fact,
                      answer,
                      subject,
                      json.dumps(keywords, ensure_ascii=False),
                      (raw_text or "").strip(),
                  ),
              )
              self.db.commit()
              self._debug(
                  f"write stored id={cursor.lastrowid} fact={fact[:80]} keywords={len(keywords)}"
              )
      
          def read(self, query: Query) -> str:
              """
              Retrieve relevant facts and synthesize a compact memory string (<=3000 chars).
              """
              question = (query.question or "").strip()
              focus = (query.focus or "").strip()
              if not question and focus:
                  question = focus
              if not question and query.keywords:
                  question = " ".join(query.keywords)
              if not question:
                  return "No query provided."
      
              rows = self.db.execute(
                  "SELECT id, fact, answer, subject, keywords_json, raw_text FROM kb_items ORDER BY id DESC LIMIT 2000"
              ).fetchall()
              if not rows:
                  self._debug("read: empty store")
                  return "No information stored."
      
              # Build normalized query terms from both explicit keywords and free-form question.
              q_terms: list[str] = []
              for part in list(query.keywords or []) + [question, focus]:
                  q_terms.extend(self._tokenize(part))
              # Preserve order while deduplicating.
              dedup_terms: list[str] = []
              seen = set()
              for t in q_terms:
                  if t not in seen:
                      seen.add(t)
                      dedup_terms.append(t)
              q_terms = dedup_terms
      
              q_norm = self._normalize_text(question)
              f_norm = self._normalize_text(focus)
              q_term_set = set(q_terms)
      
              scored = []
              for row in rows:
                  row_id, fact, answer, subject, keywords_json, raw_text = row
                  searchable = " ".join([fact or "", answer or "", subject or "", raw_text or ""])
                  s_norm = self._normalize_text(searchable)
                  s_tokens = set(self._tokenize(searchable))
      
                  try:
                      row_kw = set(json.loads(keywords_json or "[]"))
                  except Exception:
                      row_kw = set()
      
                  overlap_token = len(q_term_set & s_tokens)
                  overlap_kw = len(q_term_set & row_kw)
                  score = float(overlap_token * 2 + overlap_kw * 3)
      
                  # Phrase boosts improve precision for exact-question matches.
                  if q_norm and q_norm in s_norm:
                      score += 6.0
                  if f_norm and f_norm in s_norm:
                      score += 5.0
                  for t in q_terms:
                      # Digits/hyphen tokens are often high-value identifiers.
                      if any(ch.isdigit() for ch in t) and t in s_norm:
                          score += 2.0
      
                  scored.append((score, row))
      
              scored.sort(key=lambda x: (x[0], x[1][0]), reverse=True)
              positive = [x for x in scored if x[0] > 0]
              top = positive[:8] if positive else scored[:5]
              if not top:
                  return "No relevant information found in memory."
      
              snippets: list[str] = []
              for idx, (score, row) in enumerate(top, start=1):
                  _, fact, answer, subject, _, raw_text = row
                  fact = (fact or "").strip()
                  line = f"[{idx}] {fact}"
                  if answer and answer.strip() and answer.strip().lower() not in fact.lower():
                      line += f" | value: {answer.strip()}"
                  if subject and subject.strip() and subject.strip().lower() not in fact.lower():
                      line += f" | subject: {subject.strip()}"
                  if raw_text and raw_text.strip() and raw_text.strip() != fact:
                      src = re.sub(r"\s+", " ", raw_text.strip())
                      line += f" | source: {src[:180]}"
                  line += f" | score={score:.1f}"
                  snippets.append(line)
      
              snippet_block = "\n".join(snippets)
              self._debug(
                  f"read query='{question[:80]}' rows={len(rows)} candidates={len(top)} terms={len(q_terms)}"
              )
      
              # One LLM call for final synthesis (budget-compliant) with strict grounding instructions.
              synthesis = ""
              try:
                  synthesis = self.toolkit.llm_completion(
                      [
                          {
                              "role": "system",
                              "content": (
                                  "You synthesize retrieval output for QA. Use ONLY the provided snippets. "
                                  "Copy identifiers/codes exactly. If not answerable, say: "
                                  "'Insufficient evidence in memory.'"
                              ),
                          },
                          {
                              "role": "user",
                              "content": (
                                  f"Question: {question}\n"
                                  f"Focus: {focus or '(none)'}\n\n"
                                  f"Snippets:\n{snippet_block}\n\n"
                                  "Return exactly:\n"
                                  "Best answer candidate: <short text>\n"
                                  "Evidence: <snippet numbers and short quotes>"
                              ),
                          },
                      ],
                      temperature=0,
                  )
              except Exception as exc:
                  self._debug(f"read synthesis failure: {exc}")
      
              if synthesis and synthesis.strip():
                  result = synthesis.strip() + "\n\nTop snippets:\n" + "\n".join(snippets[:3])
              else:
                  # Deterministic fallback if LLM call fails.
                  result = "Relevant memory snippets:\n" + snippet_block
      
              return result[:3000]
  
    ''',
    'round1_score': 0.0,
    'round2_output': 'DELTA-7742',
    'round2_score': 1.0,
  })
