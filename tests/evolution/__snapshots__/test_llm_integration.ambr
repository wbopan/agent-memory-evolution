      INSTRUCTION_QUERY = "Formulate a retrieval query based on the user's information need, structured according to the Query schema."
      INSTRUCTION_RESPONSE = "Generate a concise, accurate answer based on the retrieved information, using a clear and helpful style."
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "The raw text content of the observation"})
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "The raw text query for retrieving information"})
      
