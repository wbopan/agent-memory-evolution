      from dataclasses import dataclass, field
      
      INSTRUCTION_OBSERVATION = "Extract concise factual statements from the user's input that matter to the task."
      INSTRUCTION_QUERY = "Generate a focused query describing the knowledge you need retrieved from the base."
      INSTRUCTION_RESPONSE = "Answer clearly and briefly, referencing only stored knowledge."
      
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "Raw textual observation describing the user's input."})
      
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "Raw textual query representing what to retrieve."})
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
      
          def write(self, observation: Observation) -> None:
              self.store.append(observation.raw)
      
          def read(self, query: Query) -> str:
              if not self.store:
                  return ""
              response = " ".join(self.store[-5:])
              return response[:1000]
  
