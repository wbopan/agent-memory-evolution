      from dataclasses import dataclass, field
      
      
      INSTRUCTION_OBSERVATION = "Extract and capture the most relevant facts from the provided input for later retrieval."
      INSTRUCTION_QUERY = "Formulate a focused query that describes the needed information succinctly."
      INSTRUCTION_RESPONSE = "Provide a concise, actionable response referencing stored knowledge when appropriate."
      
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "Raw textual observation captured for the knowledge base."})
      
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "Raw query text describing the needed information."})
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store = []
      
          def write(self, observation: Observation) -> None:
              self.store.append(observation.raw)
              self.toolkit.logger.debug(f"Stored: {observation.raw[:80]}")
      
          def read(self, query: Query) -> str:
              self.toolkit.logger.debug(f"Query received: {query.raw}")
              result = "\n".join(self.store) if self.store else "No information stored."
              return result[:1000]
