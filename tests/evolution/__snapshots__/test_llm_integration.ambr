# name: test_runtime_violation_fix_oversized_read
  dict({
    'fixed_code': '''
      from dataclasses import dataclass, field
      
      INSTRUCTION_OBSERVATION = "Summarize new information into concise, structured entries for storage."
      INSTRUCTION_QUERY = "Formulate retrieval requests that focus on the relevant stored context."
      INSTRUCTION_RESPONSE = "Answer using only stored knowledge, keeping responses concise and grounded."
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "The raw text content representing the new knowledge to store."})
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "The text describing the context or intent for retrieval."})
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
      
          def write(self, observation: Observation) -> None:
              self.toolkit.logger.debug(f"Writing observation of length {len(observation.raw)}")
              self.store.append(observation.raw)
      
          def read(self, query: Query) -> str:
              aggregated = " ".join(self.store)
              result = aggregated[:1000]
              self.toolkit.logger.debug(f"Read query '{query.raw}' yielding {len(result)} characters")
              return result
    ''',
    'runtime_violation': 'kb.read() returned 5000 chars (limit: 1000)',
  })
