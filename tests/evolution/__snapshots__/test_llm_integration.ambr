# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      from dataclasses import dataclass, field
      import re
      import sqlite3
      
      # These instructions are consumed by the task agent prompts.
      # Keep them explicit and concise so observation/query generation is reliable.
      INSTRUCTION_OBSERVATION = (
          "Extract the key factual statement(s) from the provided text and store them verbatim "
          "or near-verbatim in a concise single raw string. Preserve critical names, IDs, codes, and numbers."
      )
      
      INSTRUCTION_QUERY = (
          "Convert the user question into a direct retrieval query string that keeps the important entities "
          "and requested fact exactly (project names, people, codes, dates, identifiers)."
      )
      
      INSTRUCTION_RESPONSE = (
          "Answer using only retrieved memory. Be concise and factual. If memory is insufficient, say you do not know."
      )
      
      
      @dataclass
      class Observation:
          # JSON-compatible field type with description for the external LLM.
          raw: str = field(
              metadata={
                  "description": "Concise factual memory text to store (include exact names/codes/values)."
              }
          )
      
      
      @dataclass
      class Query:
          # JSON-compatible field type with description for the external LLM.
          raw: str = field(
              metadata={
                  "description": "Raw natural-language retrieval query containing the key entities and requested fact."
              }
          )
      
      
      class KnowledgeBase:
          """
          Simple deterministic KB:
          - write(): stores raw observation text in SQLite.
          - read(): keyword-overlap retrieval over recent rows, returns short snippets (<=1000 chars).
          Design goal: fast, robust, no LLM calls, and easy to debug.
          """
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db: sqlite3.Connection = toolkit.db
      
              # WHY: SQLite storage is durable for the run and simple to query quickly.
              self.db.execute(
                  """
                  CREATE TABLE IF NOT EXISTS memories (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      raw TEXT NOT NULL
                  )
                  """
              )
              self.db.commit()
              self.toolkit.logger.debug("KnowledgeBase initialized; table 'memories' is ready.")
      
          def write(self, observation: Observation) -> None:
              text = (observation.raw or "").strip()
              if not text:
                  self.toolkit.logger.debug("write() skipped empty observation.")
                  return
      
              # Normalize whitespace so retrieval is more stable.
              text = re.sub(r"\s+", " ", text)
      
              self.db.execute("INSERT INTO memories(raw) VALUES (?)", (text,))
              self.db.commit()
              self.toolkit.logger.debug(f"write() stored memory: {text[:120]}")
      
          def read(self, query: Query) -> str:
              q = (query.raw or "").strip()
              self.toolkit.logger.debug(f"read() query='{q[:120]}'")
      
              rows = self.db.execute(
                  "SELECT id, raw FROM memories ORDER BY id DESC LIMIT 300"
              ).fetchall()
      
              if not rows:
                  self.toolkit.logger.debug("read(): no rows in memory.")
                  return "No information stored."
      
              def tokenize(s: str) -> set[str]:
                  # WHY: lightweight tokenization is fast and good enough for factual matching.
                  return set(re.findall(r"[a-z0-9]+", s.lower()))
      
              q_tokens = tokenize(q)
              q_lower = q.lower()
      
              scored = []
              for row_id, text in rows:
                  t_lower = text.lower()
                  t_tokens = tokenize(text)
      
                  score = 0
                  if q_lower and q_lower in t_lower:
                      score += 100  # strong bonus for direct phrase match
                  if q_tokens:
                      score += len(q_tokens & t_tokens)  # token overlap
      
                  # Include rows that have some evidence of relevance.
                  if score > 0:
                      scored.append((score, row_id, text))
      
              # Fallback: if no overlap found, return the most recent snippets.
              if not scored:
                  self.toolkit.logger.debug("read(): no overlap matches; returning recent fallback.")
                  candidates = [text for _, text in rows[:3]]
              else:
                  scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
                  candidates = [t for _, _, t in scored[:3]]
                  self.toolkit.logger.debug(
                      f"read(): matched {len(scored)} rows; top score={scored[0][0]}"
                  )
      
              # Build compact output for downstream answer model.
              result = "\n".join(f"- {c}" for c in candidates)
      
              # Hard cap required by runtime constraints.
              if len(result) > 1000:
                  result = result[:997] + "..."
      
              return result
    ''',
    'round1_score': 0.0,
    'round2_output': "Project Zephyr's access code is DELTA-7742.",
    'round2_score': 1.0,
  })
