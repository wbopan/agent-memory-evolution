# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      from dataclasses import dataclass, field
      import re
      
      INSTRUCTION_KNOWLEDGE_ITEM = (
          "Extract a concise factual memory from the provided text. Preserve exact "
          "identifiers, codes, names, and numbers when present."
      )
      INSTRUCTION_QUERY = (
          "Create a short retrieval query containing the key entities and terms needed "
          "to find the requested fact."
      )
      INSTRUCTION_RESPONSE = (
          "Answer using the retrieved memory. Be concise and factual. If a specific value "
          "like a code is requested, return it exactly."
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Prefer exact lexical matching for factual recall (codes, IDs, names, dates). "
          "When uncertain, do not invent values."
      )
      
      
      @dataclass
      class KnowledgeItem:
          # Single JSON-safe text field keeps extraction robust while still allowing
          # arbitrary facts to be captured.
          raw: str = field(
              metadata={"description": "A concise factual statement to store in memory."}
          )
      
      
      @dataclass
      class Query:
          # Query text used for deterministic lexical retrieval.
          raw: str = field(
              metadata={"description": "A short text query describing the fact to retrieve."}
          )
      
      
      class KnowledgeBase:
          """Lightweight lexical memory with deterministic retrieval."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              # Store raw text plus normalized tokens for fast overlap scoring.
              self.store: list[dict] = []
      
          def _tokenize(self, text: str) -> list[str]:
              # Simple tokenizer: lowercased alphanumerics only.
              # Deterministic and fast, avoiding LLM calls in read/write.
              return re.findall(r"[a-z0-9]+", text.lower())
      
          def write(self, item: KnowledgeItem, raw_text: str = "") -> None:
              # Prefer structured extraction, but fall back to source text if needed.
              text = (item.raw or "").strip() or (raw_text or "").strip()
              if not text:
                  self.toolkit.logger.debug("Write skipped: empty knowledge item.")
                  return
              self.store.append({"text": text, "tokens": set(self._tokenize(text))})
              self.toolkit.logger.debug(f"Stored item. chars={len(text)} total={len(self.store)}")
      
          def read(self, query: Query) -> str:
              q = (query.raw or "").strip()
              self.toolkit.logger.debug(f"Read query='{q[:80]}' store_size={len(self.store)}")
      
              if not self.store:
                  return "No relevant information found."
              if not q:
                  # Safe fallback: return most recent item, bounded.
                  text = self.store[-1]["text"]
                  return text[:1000] if len(text) <= 1000 else text[:997] + "..."
      
              q_tokens = set(self._tokenize(q))
              q_lower = q.lower()
              scored = []
              for idx, row in enumerate(self.store):
                  overlap = len(q_tokens & row["tokens"]) if q_tokens else 0
                  phrase_bonus = 3 if q_lower and q_lower in row["text"].lower() else 0
                  score = overlap + phrase_bonus
                  if score > 0:
                      # Recency tie-breaker via idx.
                      scored.append((score, idx, row["text"]))
      
              if not scored:
                  return "No relevant information found."
      
              scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
              top_texts = []
              seen = set()
              for _, _, txt in scored:
                  if txt not in seen:
                      seen.add(txt)
                      top_texts.append(txt)
                  if len(top_texts) >= 3:
                      break
      
              result = "\n".join(top_texts)
              # Hard cap required by runtime constraints.
              return result[:1000] if len(result) <= 1000 else result[:997] + "..."
  
    ''',
    'round1_score': 0.0,
    'round2_output': 'DELTA-7742',
    'round2_score': 1.0,
  })
