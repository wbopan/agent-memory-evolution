# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      import re
      from dataclasses import dataclass, field
      
      INSTRUCTION_KNOWLEDGE_ITEM = (
          "Extract concrete factual statements from the provided text. "
          "Preserve exact values (codes, IDs, names, numbers) verbatim."
      )
      INSTRUCTION_QUERY = (
          "Convert the user question into a concise retrieval query that keeps key entities and requested facts."
      )
      INSTRUCTION_RESPONSE = (
          "Answer using the retrieved memory. Be concise and include exact values when available."
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Prefer exact string matches for sensitive values like access codes, identifiers, and credentials."
      )
      
      
      @dataclass
      class KnowledgeItem:
          """Single memory snippet stored as plain text for deterministic retrieval."""
          raw: str = field(metadata={"description": "Raw fact text to store exactly as written."})
      
      
      @dataclass
      class Query:
          """Plain-text retrieval query."""
          raw: str = field(
              metadata={"description": "User information need as short text with key entities/keywords."}
          )
      
      
      class KnowledgeBase:
          """Simple lexical memory with lightweight ranking and strict output truncation."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              # Keep in-process memory for speed and reliability (no LLM calls, no heavy indexing).
              self.store: list[str] = []
              # Small stopword list improves keyword overlap scoring by reducing noise terms.
              self._stopwords = {
                  "the", "is", "a", "an", "of", "to", "in", "on", "for", "and", "or",
                  "what", "which", "who", "where", "when", "why", "how", "please"
              }
      
          def write(self, item: KnowledgeItem) -> None:
              text = (item.raw or "").strip()
              if not text:
                  # Ignore empty writes to avoid polluting retrieval results.
                  self.toolkit.logger.debug("Ignored empty knowledge item.")
                  return
              self.store.append(text)
              self.toolkit.logger.debug(f"Stored item #{len(self.store)}: {text[:120]}")
      
          def _tokens(self, text: str) -> set[str]:
              # Regex tokenization is deterministic and fast; keeps alphanumerics like DELTA-7742 as two useful parts.
              toks = re.findall(r"[a-z0-9]+", text.lower())
              return {t for t in toks if t and t not in self._stopwords}
      
          def read(self, query: Query) -> str:
              q = (query.raw or "").strip()
              self.toolkit.logger.debug(f"Read query: {q[:120]} | store size: {len(self.store)}")
              if not self.store:
                  return "No information stored."
      
              q_tokens = self._tokens(q)
              scored: list[tuple[int, str]] = []
              q_lower = q.lower()
      
              for text in self.store:
                  t_tokens = self._tokens(text)
                  # Overlap score gives robust retrieval without expensive embedding calls.
                  overlap = len(q_tokens & t_tokens)
                  # Phrase boost helps when the knowledge sentence directly mirrors the question subject.
                  phrase_boost = 2 if q_lower and any(tok in text.lower() for tok in q_tokens) else 0
                  score = overlap + phrase_boost
                  if score > 0:
                      scored.append((score, text))
      
              if not scored:
                  # Fallback: return the most recent memory snippet when no lexical match exists.
                  result = self.store[-1]
                  return result[:1000]
      
              # Highest score first; keep only a few snippets to stay focused and within output budget.
              scored.sort(key=lambda x: x[0], reverse=True)
              top_texts = [text for _, text in scored[:3]]
              result = "\n".join(top_texts)
              # Hard cap required by interface constraints.
              return result[:1000]
  
    ''',
    'round1_score': 0.0,
    'round2_output': 'DELTA-7742',
    'round2_score': 1.0,
  })
