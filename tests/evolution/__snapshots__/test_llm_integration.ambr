# name: test_runtime_violation_fix_oversized_read
  dict({
    'fixed_code': '''
      from dataclasses import dataclass, field
      
      INSTRUCTION_OBSERVATION = "Record the agent's observation in plain language, capturing the newest fact or update."
      INSTRUCTION_QUERY = "Formulate a query to retrieve relevant stored information concisely."
      INSTRUCTION_RESPONSE = "Respond with a clear summary referencing stored knowledge; keep it under 1000 characters."
      ALWAYS_ON_KNOWLEDGE = "Knowledge base stores short textual observations."
      
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "Raw text describing what was observed in the task environment."})
      
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "Text describing what knowledge is being requested."})
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
      
          def write(self, observation: Observation) -> None:
              self.store.append(observation.raw)
      
          def read(self, query: Query) -> str:
              combined = " ".join(self.store)
              if not combined:
                  return ""
              result = combined[-1000:]
              self.toolkit.logger.debug(f"read result length {len(result)}")
              return result
  
    ''',
    'runtime_violation': 'kb.read() returned 5000 chars (limit: 1000)',
  })
