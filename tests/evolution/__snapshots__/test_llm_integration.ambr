      +import json
      +from dataclasses import dataclass, field
      +from typing import List, Optional
      +
      +INSTRUCTION_KNOWLEDGE_ITEM = (
      +    "Extract the most important fact from the text, add relevant supporting details, and list descriptive topics. "
      +    "Return JSON that conforms to the KnowledgeItem schema."
      +)
      +INSTRUCTION_QUERY = (
      +    "Translate the user's request into keywords and a desired number of top matches using JSON that conforms to the Query schema."
      +)
      +INSTRUCTION_RESPONSE = (
      +    "Answer in 1-3 concise sentences by summarizing only the retrieved knowledge and citing its source. "
      +    "Keep the response under 1000 characters."
      +)
      +ALWAYS_ON_KNOWLEDGE = "Always search the knowledge base for evidence before answering a user question."
      +
      +
      +@dataclass
      +class KnowledgeItem:
      +    """Structured facts extracted from a text source."""
      +    summary: str = field(metadata={"description": "A single-sentence summary capturing the most important fact from the text."})
      +    details: Optional[str] = field(
      +        default=None,
      +        metadata={"description": "Supporting or contextual details that augment the main summary."},
      +    )
      +    source: Optional[str] = field(
      +        default=None,
      +        metadata={"description": "The origin of the information, such as a document title or URL."},
      +    )
      +    topics: List[str] = field(
      +        default_factory=list,
      +        metadata={"description": "Keywords or tags that describe the main concepts discussed in the text."},
      +    )
      +
      +
      +@dataclass
      +class Query:
      +    """Structured parameters for retrieving knowledge."""
      +    keywords: List[str] = field(
      +        default_factory=list,
      +        metadata={"description": "Keywords that describe the user's question or intent."},
      +    )
      +    top_k: int = field(
      +        default=3,
      +        metadata={"description": "Maximum number of matching knowledge items to return (1-5)."},
      +    )
      +
      +
      +class KnowledgeBase:
      +    """A SQLite-backed knowledge base that supports keyword filtering and bounded responses."""
      +
      +    def __init__(self, toolkit):
      +        self.toolkit = toolkit
      +        # Keep responses under 1000 characters by trimming the assembled answer.
      +        self._max_response_chars = 950
      +        cursor = self.toolkit.db.cursor()
      +        # Persist summaries, details, topics, and raw text so that queries can search by keyword.
      +        cursor.execute(
      +            """
      +            CREATE TABLE IF NOT EXISTS knowledge (
      +                id INTEGER PRIMARY KEY AUTOINCREMENT,
      +                summary TEXT NOT NULL,
      +                details TEXT,
      +                source TEXT,
      +                topics TEXT,
      +                raw_text TEXT NOT NULL
      +            )
      +            """
      +        )
      +        self.toolkit.db.commit()
      +
      +    def write(self, item: KnowledgeItem, raw_text: str) -> None:
      +        cursor = self.toolkit.db.cursor()
      +        topics_json = json.dumps(item.topics or [])
      +        cursor.execute(
      +            """
      +            INSERT INTO knowledge (summary, details, source, topics, raw_text)
      +            VALUES (?, ?, ?, ?, ?)
      +            """,
      +            (item.summary, item.details, item.source, topics_json, raw_text),
      +        )
      +        self.toolkit.db.commit()
      +        self.toolkit.logger.debug(f"Stored knowledge: {item.summary}")
      +
      +    def read(self, query: Query) -> str:
      +        cursor = self.toolkit.db.cursor()
      +        base_query = "SELECT summary, details, source, topics, raw_text FROM knowledge"
      +        params: List[str] = []
      +        conditions: List[str] = []
      +        if query.keywords:
      +            # Build a WHERE clause that ensures every keyword appears in at least one searchable field.
      +            for keyword in query.keywords:
      +                like_pattern = f"%{keyword}%"
      +                search_fields = ["summary", "details", "source", "raw_text"]
      +                field_conditions = []
      +                for field_name in search_fields:
      +                    field_conditions.append(f"{field_name} LIKE ?")
      +                    params.append(like_pattern)
      +                conditions.append("(" + " OR ".join(field_conditions) + ")")
      +        if conditions:
      +            base_query += " WHERE " + " AND ".join(conditions)
      +        limit = max(1, min(query.top_k, 5))
      +        base_query += " ORDER BY id DESC LIMIT ?"
      +        params.append(str(limit))
      +        rows = cursor.execute(base_query, params).fetchall()
      +        self.toolkit.logger.debug(f"Query keywords={query.keywords} returning {len(rows)} rows.")
      +        if not rows:
      +            return "No matching knowledge stored."
      +
      +        snippets: List[str] = []
      +        for summary, details, source, topics_json, raw_text in rows:
      +            topic_list = json.loads(topics_json or "[]")
      +            snippet_parts = [summary]
      +            if details:
      +                snippet_parts.append(details)
      +            if source:
      +                snippet_parts.append(f"Source: {source}")
      +            if topic_list:
      +                snippet_parts.append("Topics: " + ", ".join(topic_list))
      +            if raw_text:
      +                excerpt = raw_text.replace("\n", " ").strip()
      +                if len(excerpt) > 120:
      +                    excerpt = excerpt[:120] + "…"
      +                snippet_parts.append(f"Excerpt: {excerpt}")
      +            snippet = " | ".join(snippet_parts)
      +            if len(snippet) > 400:
      +                snippet = snippet[:400] + "…"
      +            projected = "\n".join(snippets + [snippet])
      +            if len(projected) > self._max_response_chars:
      +                break
      +            snippets.append(snippet)
      +        result = "\n".join(snippets)[: self._max_response_chars]
      +        return result if result else "No matching knowledge stored."
      *** End Patch
    ''',
