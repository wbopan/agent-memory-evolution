# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      import re
      from dataclasses import dataclass, field
      
      INSTRUCTION_OBSERVATION = (
          "Extract concrete, self-contained facts from the provided text. "
          "Keep wording faithful and include exact identifiers/codes when present."
      )
      INSTRUCTION_QUERY = (
          "Write a focused retrieval query that preserves key entities and attributes "
          "(names, IDs, codes, dates, locations) needed to find the answer."
      )
      INSTRUCTION_RESPONSE = (
          "Answer using retrieved memory only. Be concise and factual. "
          "If memory is insufficient, say you do not have enough information."
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Stored notes may contain exact short answers (e.g., access codes). "
          "Prefer exact copied values from memory over paraphrasing."
      )
      
      
      @dataclass
      class Observation:
          """Single memory item to store."""
          raw: str = field(
              metadata={
                  "description": (
                      "A concise factual observation to store verbatim. "
                      "Include exact names, numbers, and codes."
                  )
              }
          )
      
      
      @dataclass
      class Query:
          """User information need for retrieval."""
          raw: str = field(
              metadata={
                  "description": (
                      "A natural-language search query describing what fact is needed."
                  )
              }
          )
      
      
      class KnowledgeBase:
          """Simple lexical-memory KB.
      
          Design intent:
          - Keep writes O(1) and reads lightweight (<5s budget).
          - Use deterministic token-overlap retrieval (no LLM calls needed).
          - Return only a short, relevant subset of memory (<=1000 chars).
          """
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: list[str] = []
              # Tiny stopword set improves matching quality by focusing on content terms.
              self._stopwords = {
                  "the", "is", "a", "an", "and", "or", "to", "of", "in", "on", "for",
                  "with", "what", "who", "when", "where", "why", "how", "are", "was",
                  "were", "be", "been", "it", "its", "as", "at", "by", "from", "that",
                  "this", "these", "those", "do", "does", "did"
              }
      
          def _tokenize(self, text: str) -> set[str]:
              # Deterministic tokenizer: fast and robust for short factual notes.
              tokens = re.findall(r"[a-zA-Z0-9]+", text.lower())
              return {t for t in tokens if t and t not in self._stopwords}
      
          def write(self, observation: Observation) -> None:
              # Ignore empty writes to keep memory clean and retrieval precise.
              text = (observation.raw or "").strip()
              if not text:
                  self.toolkit.logger.debug("Skipped empty observation.")
                  return
              self.store.append(text)
              self.toolkit.logger.debug(f"Stored observation #{len(self.store)}: {text[:120]}")
      
          def read(self, query: Query) -> str:
              q = (query.raw or "").strip()
              self.toolkit.logger.debug(f"Read query: {q[:120]} | store_size={len(self.store)}")
      
              if not self.store:
                  return "No information stored."
      
              q_tokens = self._tokenize(q)
              scored: list[tuple[float, int, str]] = []
      
              # Score memories by lexical overlap; this reliably surfaces exact fact lines.
              for idx, text in enumerate(self.store):
                  t_tokens = self._tokenize(text)
                  overlap = len(q_tokens & t_tokens)
                  score = float(overlap)
                  if q and q.lower() in text.lower():
                      score += 5.0
                  if q_tokens and q_tokens.issubset(t_tokens):
                      score += 2.0
                  if score > 0:
                      scored.append((score, idx, text))
      
              if scored:
                  # Higher score first; tie-break by recency (higher idx).
                  scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
                  candidates = [text for _, _, text in scored[:5]]
              else:
                  # Fallback: return only recent notes, not the whole store.
                  candidates = self.store[-3:]
      
              # Hard cap output to 1000 chars to satisfy runtime constraints.
              prefix = "Relevant memory:\n"
              max_len = 1000
              lines: list[str] = []
              for text in candidates:
                  line = f"- {text.strip()}"
                  tentative = prefix + ("\n".join(lines + [line]) if lines else line)
                  if len(tentative) <= max_len:
                      lines.append(line)
                  else:
                      break
      
              if not lines:
                  # Worst-case fallback still obeys 1000-char cap.
                  return (prefix + f"- {candidates[0]}")[:1000]
              return (prefix + "\n".join(lines))[:1000]
  
    ''',
    'round1_score': 0.0,
    'round2_output': 'Project Zephyr access code is DELTA-7742.',
    'round2_score': 1.0,
  })
