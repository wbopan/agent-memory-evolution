  dict({
    'fixed_code': '''
      from dataclasses import dataclass, field
      from typing import Optional, List
      import sqlite3
      import chromadb
      import json
      import hashlib
      from datetime import datetime
      
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "The raw observation text to store in memory"})
          timestamp: Optional[str] = field(default=None, metadata={"description": "Optional timestamp of the observation"})
          tags: List[str] = field(default_factory=list, metadata={"description": "Optional tags for categorizing the observation"})
      
      
      @dataclass
      class Query:
          search_text: str = field(metadata={"description": "Text to search for in memory"})
          max_results: int = field(default=5, metadata={"description": "Maximum number of results to return"})
          tags_filter: Optional[List[str]] = field(default=None, metadata={"description": "Optional tags to filter results by"})
      
      
      class Memory:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store: List[str] = []
              
              # Initialize database tables
              self._init_db()
              
              # Initialize ChromaDB collection
              self.chroma_client = toolkit.chroma
              self.collection = self.chroma_client.create_collection(
                  name="memory_embeddings",
                  metadata={"hnsw:space": "cosine"}
              )
              
              self.toolkit.logger.debug("Memory system initialized")
      
          def _init_db(self):
              """Initialize SQLite database tables"""
              cursor = self.toolkit.db.cursor()
              cursor.execute("""
                  CREATE TABLE IF NOT EXISTS observations (
                      id TEXT PRIMARY KEY,
                      raw TEXT NOT NULL,
                      timestamp TEXT,
                      tags TEXT,
                      created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                  )
              """)
              self.toolkit.db.commit()
              self.toolkit.logger.debug("Database tables initialized")
      
          def _generate_id(self, text: str) -> str:
              """Generate a unique ID for an observation"""
              return hashlib.sha256(text.encode()).hexdigest()[:16]
      
          def write(self, observation: Observation) -> None:
              """Store information in memory"""
              try:
                  # Generate unique ID
                  obs_id = self._generate_id(observation.raw)
                  
                  # Store in SQLite
                  cursor = self.toolkit.db.cursor()
                  cursor.execute("""
                      INSERT OR REPLACE INTO observations (id, raw, timestamp, tags)
                      VALUES (?, ?, ?, ?)
                  """, (
                      obs_id,
                      observation.raw,
                      observation.timestamp or datetime.now().isoformat(),
                      json.dumps(observation.tags)
                  ))
                  self.toolkit.db.commit()
                  
                  # Store embedding in ChromaDB
                  self.collection.add(
                      documents=[observation.raw],
                      metadatas=[{
                          "id": obs_id,
                          "timestamp": observation.timestamp or datetime.now().isoformat(),
                          "tags": json.dumps(observation.tags)
                      }],
                      ids=[obs_id]
                  )
                  
                  self.toolkit.logger.debug(f"Observation written with ID: {obs_id}")
                  
              except Exception as e:
                  self.toolkit.logger.debug(f"Error writing observation: {str(e)}")
                  raise
      
          def read(self, query: Query) -> str:
              """Retrieve relevant information from memory"""
              try:
                  # Search in ChromaDB
                  results = self.collection.query(
                      query_texts=[query.search_text],
                      n_results=min(query.max_results, 10),
                      where={"tags": {"$contains": query.tags_filter[0]}} if query.tags_filter else None
                  )
                  
                  if not results['documents'] or not results['documents'][0]:
                      return "No relevant information found."
                  
                  # Format results
                  formatted_results = []
                  for i, doc in enumerate(results['documents'][0]):
                      metadata = results['metadatas'][0][i] if results['metadatas'] else {}
                      formatted_results.append(
                          f"Result {i+1}:\n"
                          f"Content: {doc[:200]}...\n"
                          f"ID: {metadata.get('id', 'N/A')}\n"
                          f"Tags: {metadata.get('tags', '[]')}\n"
                      )
                  
                  # Join results and ensure length limit
                  response = "\n---\n".join(formatted_results)
                  
                  # Enforce 1000 character limit
                  if len(response) > 1000:
                      response = response[:997] + "..."
                      
                  self.toolkit.logger.debug(f"Query processed, returning {len(response)} characters")
                  return response
                  
              except Exception as e:
                  self.toolkit.logger.debug(f"Error reading memory: {str(e)}")
                  return f"Error retrieving information: {str(e)}"
    ''',
    'runtime_violation': 'memory.read() returned 5000 chars (limit: 1000)',
  })
