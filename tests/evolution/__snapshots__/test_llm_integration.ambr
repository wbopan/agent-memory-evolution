    'patched_code': '''
      import json
      import sqlite3
      from dataclasses import dataclass, field
      from typing import List, Optional
      
      INSTRUCTION_KNOWLEDGE_ITEM = (
          "Read the source text and extract a concise fact plus the most relevant keywords that "
          "will help later retrieval. Capture any source identifier if present."
      )
      INSTRUCTION_QUERY = (
          "Translate the user’s question into a list of important keywords or concepts. "
          "If there is a narrower focus, include it so the retrieval can be guided precisely."
      )
      INSTRUCTION_RESPONSE = (
          "Answer using only the retrieved knowledge, citing facts briefly and clearly. "
          "If no stored information applies, reply with 'No information found.' Keep answers short."
      )
      ALWAYS_ON_KNOWLEDGE = (
          "Always consult the persisted knowledge before guessing, and mention when information is missing."
      )
      
      
      @dataclass
      class KnowledgeItem:
          """Structured knowledge captured from each source when writing new memories."""
          summary: str = field(metadata={"description": "Concise summary of the key fact learned"})
          tags: List[str] = field(
              default_factory=list,
              metadata={"description": "Keywords or topics that best describe the fact"},
          )
          source_id: Optional[str] = field(
              default=None, metadata={"description": "Optional identifier for the raw source text"}
          )
      
      
      @dataclass
      class Query:
          """Structured query parameters used for knowledge retrieval."""
          keywords: List[str] = field(
              default_factory=list,
              metadata={"description": "Important keywords that should appear in relevant knowledge"},
          )
          focus: Optional[str] = field(
              default=None,
              metadata={"description": "Optional clarifying detail to bias the search toward specific facts"},
          )
      
      
      class KnowledgeBase:
          """Knowledge base that persists structured items in SQLite and retrieves them via keyword matching."""
      
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.db: sqlite3.Connection = toolkit.db
              # Create a simple table with tags stored as JSON so we can search summaries/raw efficiently.
              self.db.execute(
                  """
                  CREATE TABLE IF NOT EXISTS knowledge (
                      summary TEXT NOT NULL,
                      tags TEXT NOT NULL,
                      source_id TEXT,
                      raw TEXT NOT NULL
                  )
                  """
              )
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_summary ON knowledge(summary)")
              self.db.execute("CREATE INDEX IF NOT EXISTS idx_raw ON knowledge(raw)")
              self.db.commit()
      
          def write(self, item: KnowledgeItem, raw_text: str) -> None:
              """Store the structured item along with the original text for future retrieval."""
              tags_json = json.dumps(item.tags)
              self.db.execute(
                  "INSERT INTO knowledge (summary, tags, source_id, raw) VALUES (?, ?, ?, ?)",
                  (item.summary, tags_json, item.source_id, raw_text),
              )
              self.db.commit()
              self.toolkit.logger.debug(
                  f"Stored knowledge summary='{item.summary[:50]}...' with tags={item.tags} source={item.source_id}"
              )
      
          def read(self, query: Query) -> str:
              """Find the most relevant stored summaries via keyword matching, then return a concise digest."""
              self.toolkit.logger.debug(
                  f"Retrieving knowledge with keywords={query.keywords} focus={query.focus}"
              )
      
              params = []
              where_clauses = []
      
              def add_like_clause(value: str) -> str:
                  """Helper to add case-insensitive LIKE clauses safely."""
                  sanitized = f"%{value.strip().lower()}%" if value.strip() else "%"
                  params.extend([sanitized, sanitized])
                  return "(LOWER(summary) LIKE ? OR LOWER(raw) LIKE ?)"
      
              for keyword in query.keywords:
                  if keyword:
                      where_clauses.append(add_like_clause(keyword))
      
              if query.focus:
                  where_clauses.append(add_like_clause(query.focus))
      
              if where_clauses:
                  sql = f"""
                      SELECT summary, raw FROM knowledge
                      WHERE {" OR ".join(where_clauses)}
                      ORDER BY rowid DESC
                      LIMIT 5
                  """
              else:
                  sql = """
                      SELECT summary, raw FROM knowledge
                      ORDER BY rowid DESC
                      LIMIT 5
                  """
      
              rows = list(self.db.execute(sql, params))
              if not rows:
                  self.toolkit.logger.debug("Read found no matching knowledge.")
                  return "No information found."
      
              self.toolkit.logger.debug(f"Read returned {len(rows)} candidate(s).")
      
              parts = []
              for idx, (summary, raw) in enumerate(rows, 1):
                  snippet = raw.strip().split("\n", 1)[0][:80]
                  parts.append(f"{idx}. {summary} (source snippet: {snippet})")
      
              result = "\n".join(parts)
              if len(result) > 1000:
                  result = result[:997].rstrip() + "..."
      
              return result
  
    ''',
    'prompt': '''
      You are an expert Python programmer specializing in knowledge base system design.
      
