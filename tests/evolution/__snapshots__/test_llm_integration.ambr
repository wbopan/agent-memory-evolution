# name: test_reflection_recovery
  dict({
    'reflected_code': '''
      import json
      import re
      import sqlite3
      from dataclasses import dataclass, field
      from typing import Optional, List
      from datetime import datetime
      
      # Instruction constants as required by the interface spec
      INSTRUCTION_OBSERVATION = """
      Extract structured information from the document text. Identify the main entity, its attributes, and values.
      Focus on factual information like codes, numbers, dates, names, and key details.
      """
      INSTRUCTION_QUERY = """
      Formulate a query to retrieve specific information from the knowledge base.
      Specify what entity and attribute you're looking for, and provide relevant keywords.
      """
      INSTRUCTION_RESPONSE = """
      Provide a concise answer based on the retrieved information. Include only the most relevant facts.
      Keep responses under 1000 characters and avoid unnecessary elaboration.
      """
      
      
      @dataclass
      class Observation:
          """Structured observation capturing key information from documents."""
          # Core entity being described
          entity: str = field(metadata={"description": "The main subject or entity being described"})
          
          # Attribute of the entity (e.g., "access code", "launch date", "director")
          attribute: str = field(metadata={"description": "The specific attribute or property of the entity"})
          
          # Value of the attribute
          value: str = field(metadata={"description": "The value of the attribute"})
          
          # Raw text for fallback retrieval
          raw: str = field(metadata={"description": "Original text for reference"})
          
          # Additional context or details
          context: Optional[str] = field(default=None, metadata={"description": "Additional context or details"})
          
          # Timestamp for recency tracking
          timestamp: str = field(default_factory=lambda: datetime.now().isoformat(), 
                                metadata={"description": "When this observation was recorded"})
      
      
      @dataclass
      class Query:
          """Structured query for retrieving information from the knowledge base."""
          # Raw query text for fallback
          raw: str = field(metadata={"description": "Original query text"})
          
          # Target entity to search for
          entity: Optional[str] = field(default=None, metadata={"description": "Entity to search for"})
          
          # Target attribute to search for
          attribute: Optional[str] = field(default=None, metadata={"description": "Attribute to search for"})
          
          # Keywords for text search
          keywords: Optional[List[str]] = field(default=None, metadata={"description": "Keywords for text search"})
      
      
      class KnowledgeBase:
          """Knowledge base with structured storage and retrieval."""
          
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.logger = toolkit.logger
              
              # Initialize SQLite database for structured storage
              self.db = toolkit.db
              self._init_database()
              
              # Initialize ChromaDB for semantic search (fallback)
              self.chroma = toolkit.chroma
              self._init_chroma()
              
              # Counter for LLM calls to stay within budget
              self.llm_call_count = 0
              
              self.logger.debug("KnowledgeBase initialized with SQLite and ChromaDB")
          
          def _init_database(self):
              """Initialize SQLite tables for structured storage."""
              cursor = self.db.cursor()
              cursor.execute("""
                  CREATE TABLE IF NOT EXISTS observations (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      entity TEXT,
                      attribute TEXT,
                      value TEXT,
                      context TEXT,
                      raw TEXT,
                      timestamp TEXT,
                      UNIQUE(entity, attribute, value) ON CONFLICT REPLACE
                  )
              """)
              
              # Create indexes for fast lookups
              cursor.execute("CREATE INDEX IF NOT EXISTS idx_entity ON observations(entity)")
              cursor.execute("CREATE INDEX IF NOT EXISTS idx_attribute ON observations(attribute)")
              cursor.execute("CREATE INDEX IF NOT EXISTS idx_entity_attribute ON observations(entity, attribute)")
              
              self.db.commit()
              self.logger.debug("SQLite database initialized")
          
          def _init_chroma(self):
              """Initialize ChromaDB collection for semantic search."""
              try:
                  self.collection = self.chroma.create_collection(
                      name="observations",
                      metadata={"hnsw:space": "cosine"}
                  )
                  self.logger.debug("ChromaDB collection initialized")
              except Exception as e:
                  self.logger.debug(f"ChromaDB collection already exists or error: {e}")
                  self.collection = self.chroma.get_collection("observations")
          
          def write(self, observation: Observation) -> None:
              """Store structured observation in both SQLite and ChromaDB."""
              # Store in SQLite for structured queries
              cursor = self.db.cursor()
              cursor.execute("""
                  INSERT OR REPLACE INTO observations 
                  (entity, attribute, value, context, raw, timestamp)
                  VALUES (?, ?, ?, ?, ?, ?)
              """, (
                  observation.entity,
                  observation.attribute,
                  observation.value,
                  observation.context,
                  observation.raw,
                  observation.timestamp
              ))
              self.db.commit()
              
              # Store in ChromaDB for semantic search (using raw text)
              try:
                  # Generate a unique ID based on content hash
                  import hashlib
                  content_hash = hashlib.md5(observation.raw.encode()).hexdigest()
                  
                  self.collection.add(
                      documents=[observation.raw],
                      metadatas=[{
                          "entity": observation.entity,
                          "attribute": observation.attribute,
                          "value": observation.value[:100] if observation.value else ""
                      }],
                      ids=[content_hash]
                  )
              except Exception as e:
                  self.logger.debug(f"ChromaDB write failed (non-critical): {e}")
              
              self.logger.debug(f"Stored observation: {observation.entity}.{observation.attribute} = {observation.value[:50]}")
          
          def read(self, query: Query) -> str:
              """
              Retrieve relevant information based on structured query.
              Returns at most 1000 characters as required.
              """
              self.logger.debug(f"Processing query: entity={query.entity}, attribute={query.attribute}, keywords={query.keywords}")
              
              results = []
              
              # Strategy 1: Exact match using SQLite (most efficient)
              if query.entity and query.attribute:
                  cursor = self.db.cursor()
                  cursor.execute("""
                      SELECT value, context, raw, timestamp 
                      FROM observations 
                      WHERE entity LIKE ? AND attribute LIKE ?
                      ORDER BY timestamp DESC
                      LIMIT 5
                  """, (f"%{query.entity}%", f"%{query.attribute}%"))
                  
                  for row in cursor.fetchall():
                      value, context, raw, timestamp = row
                      result = f"{value}"
                      if context:
                          result += f" (Context: {context[:100]})"
                      results.append(result)
              
              # Strategy 2: Keyword search if no exact match found
              if not results and query.keywords:
                  cursor = self.db.cursor()
                  keyword_conditions = []
                  params = []
                  
                  for keyword in query.keywords[:3]:  # Limit to 3 keywords
                      keyword_conditions.append("(raw LIKE ? OR entity LIKE ? OR attribute LIKE ? OR value LIKE ?)")
                      params.extend([f"%{keyword}%"] * 4)
                  
                  if keyword_conditions:
                      sql = f"""
                          SELECT value, context, raw 
                          FROM observations 
                          WHERE {' OR '.join(keyword_conditions)}
                          ORDER BY timestamp DESC
                          LIMIT 3
                      """
                      cursor.execute(sql, params)
                      
                      for row in cursor.fetchall():
                          value, context, raw = row
                          results.append(f"{value}")
                          if len(results) >= 3:
                              break
              
              # Strategy 3: Semantic search using ChromaDB as fallback
              if not results and self.llm_call_count < 10:  # Limit LLM usage
                  try:
                      # Use LLM to extract search terms from raw query
                      if self.llm_call_count < 5:  # Conservative limit
                          search_terms = self._extract_search_terms(query.raw)
                          if search_terms:
                              chroma_results = self.collection.query(
                                  query_texts=[search_terms],
                                  n_results=2
                              )
                              
                              if chroma_results['documents']:
                                  for doc in chroma_results['documents'][0]:
                                      # Extract key information using simple pattern matching
                                      extracted = self._extract_key_info(doc)
                                      if extracted:
                                          results.append(extracted)
                      self.llm_call_count += 1
                  except Exception as e:
                      self.logger.debug(f"Semantic search failed: {e}")
              
              # Strategy 4: Fallback to raw text search
              if not results:
                  cursor = self.db.cursor()
                  cursor.execute("""
                      SELECT value, raw 
                      FROM observations 
                      WHERE raw LIKE ?
                      ORDER BY timestamp DESC
                      LIMIT 2
                  """, (f"%{query.raw[:50]}%",))
                  
                  for row in cursor.fetchall():
                      value, raw = row
                      results.append(f"{value}")
              
              # Format final response
              if results:
                  # Join results, ensuring total length <= 1000 characters
                  response = " | ".join(results[:3])  # Limit to 3 most relevant results
                  if len(response) > 1000:
                      response = response[:997] + "..."
                  return response
              else:
                  # Return a helpful message instead of "No information stored"
                  return "No matching information found. Try being more specific or check if the information was previously stored."
          
          def _extract_search_terms(self, query_text: str) -> str:
              """Use LLM to extract key search terms from query (minimal usage)."""
              try:
                  messages = [
                      {"role": "system", "content": "Extract 2-3 key search terms from the query for information retrieval."},
                      {"role": "user", "content": f"Query: {query_text}\n\nReturn only the search terms separated by commas."}
                  ]
                  response = self.toolkit.llm_completion(messages, max_tokens=50)
                  return response.strip()
              except Exception as e:
                  self.logger.debug(f"LLM term extraction failed: {e}")
                  return query_text
          
          def _extract_key_info(self, text: str) -> str:
              """Extract key information using pattern matching (no LLM)."""
              # Look for patterns like "code is XXXX", "value: YYYY", etc.
              patterns = [
                  r'code[\s:]+([A-Z0-9\-]+)',
                  r'value[\s:]+([A-Za-z0-9\-\.]+)',
                  r'is[\s:]+([A-Z0-9\-]+)',
                  r'=([A-Z0-9\-]+)'
              ]
              
              for pattern in patterns:
                  match = re.search(pattern, text, re.IGNORECASE)
                  if match:
                      return match.group(1).strip()
              
              # Return first 50 characters if no pattern matches
              return text[:50].strip()
    ''',
