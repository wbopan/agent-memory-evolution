      from dataclasses import dataclass, field
      
      
      INSTRUCTION_OBSERVATION = "Extract the most important detail from the provided text for storage."
      INSTRUCTION_QUERY = "Formulate a simple keyword query that captures what should be retrieved from the knowledge base."
      INSTRUCTION_RESPONSE = "Return a concise summary of relevant stored knowledge that answers the query."
      
      def process_text(text: str) -> str:
          return text.strip()
      
      @dataclass
      class Observation:
          raw: str = field(metadata={"description": "The full text to store in the knowledge base."})
      
      
      @dataclass
      class Query:
          raw: str = field(metadata={"description": "The text describing what information to retrieve."})
      
      
      class KnowledgeBase:
          def __init__(self, toolkit):
              self.toolkit = toolkit
              self.store = []
      
          def write(self, observation: Observation) -> None:
              processed = process_text(observation.raw)
              self.store.append(processed)
      
          def read(self, query: Query) -> str:
              return "\n".join(self.store) if self.store else "No information stored."
